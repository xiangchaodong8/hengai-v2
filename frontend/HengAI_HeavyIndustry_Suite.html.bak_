          <strong id="hi-yoy-spark" class="hi-spark-pct">同比增减率 —</strong>
        </div>
        <svg class="hi-spark-svg" viewBox="0 0 200 48" preserveAspectRatio="none" aria-hidden="true">
          <path id="hi-spark-path" d="M0,28 L25,22 L50,26 L75,18 L100,24 L125,16 L150,20 L175,12 L200,14" fill="none" stroke="var(--green-l)" stroke-width="2"/>
          <path id="hi-spark-fill" d="M0,28 L25,22 L50,26 L75,18 L100,24 L125,16 L150,20 L175,12 L200,14 L200,48 L0,48 Z" fill="url(#hiSparkFill)" opacity="0.35"/>
          <defs>
            <linearGradient id="hiSparkFill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--green)"/>
              <stop offset="100%" stop-color="transparent"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="hi-spark-months" aria-hidden="true">
          <span>2024-05</span><span>2024-06</span><span>2024-07</span><span>2024-08</span><span>2024-09</span><span>2024-10</span>
        </div>
      </div>
      <div class="hi-struct-block">
