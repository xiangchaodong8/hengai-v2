<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>HengAI · 原厂资产确权</title>
<script>
if (/[?&]embed=1/.test(location.search)) document.documentElement.setAttribute('data-embed','1');
</script>
<link rel="stylesheet" href="hi-hub-tokens.css">
<link rel="stylesheet" href="style.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="config-sync.js" onerror="window.APP_CONFIG={}"></script>
<script src="AppState.js"></script>
<script src="hengai-load-appstate.js"></script>
<script src="hengai-hub-nav.js"></script>
<script src="hengai-module-pipeline.js"></script>
<script src="hengai-embed-boot.js"></script>
<script src="app.js"></script>
<style>
.hi-ind-tabs-spectrum{display:flex;flex-wrap:wrap;gap:6px;max-height:88px;overflow-y:auto;padding-bottom:4px}
.hi-ind-tabs-spectrum .hi-tab{flex:0 0 auto;font-size:11px;padding:6px 10px;white-space:nowrap}
.hi-policy-tag{font-size:11px;line-height:1.55;padding:8px 12px;border-radius:8px;margin:8px 0 0}
.hi-gd-ets{background:rgba(59,130,246,0.12);border:1px solid rgba(59,130,246,0.35);color:#93c5fd}
.hi-gd-sync{background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.35);color:#6ee7b7}
.hi-cbam-warn{background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.4);color:#fcd34d}
.hi-ind-kpi-strip{display:flex;flex-wrap:wrap;gap:8px;font-size:10.5px;color:var(--ink2);margin-top:6px}
.hi-ind-kpi-strip span{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:6px;padding:4px 8px}
.hi-pue-badge{font-size:12px;color:var(--gold-l);margin-top:6px}
.hi-eb{margin-top:12px;padding:14px 16px;border:1px solid var(--border);background:linear-gradient(135deg,rgba(16,185,129,.09),rgba(59,130,246,.07));position:relative;overflow:hidden;transition:border-color .2s ease,box-shadow .2s ease,background .2s ease}
.hi-eb:before{content:'';position:absolute;inset:-1px;background:radial-gradient(ellipse at top right,rgba(16,185,129,.2),transparent 42%);pointer-events:none;opacity:.95;transition:opacity .2s ease}
.hi-eb.state-draft{border-color:rgba(245,158,11,.35)}
.hi-eb.state-draft:before{opacity:.72}
.hi-eb.state-ready{border-color:rgba(16,185,129,.45);box-shadow:0 0 0 1px rgba(16,185,129,.12),0 14px 28px rgba(3,10,24,.25)}
.hi-eb.state-ready:before{opacity:1}
.hi-eb.state-certified{border-color:rgba(34,197,94,.52);box-shadow:0 0 0 1px rgba(34,197,94,.18),0 16px 34px rgba(4,16,20,.3)}
.hi-eb-head{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;position:relative;z-index:1}
.hi-eb-title{font-size:13px;font-weight:700;color:var(--ink1)}
.hi-eb-sub{font-size:11px;color:var(--ink2);margin-top:2px}
.hi-eb-action{font-size:11px;color:var(--teal-l);border:1px solid rgba(16,185,129,.35);background:rgba(16,185,129,.09);padding:6px 10px;border-radius:999px;transition:all .2s ease}
.hi-eb-action.warn{color:var(--gold-l);border-color:rgba(245,158,11,.4);background:rgba(245,158,11,.12)}
.hi-eb-action.ok{color:var(--green-l);border-color:rgba(16,185,129,.48);background:rgba(16,185,129,.16)}
.hi-eb-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-top:12px;position:relative;z-index:1}
.hi-eb-card{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:10px;padding:10px 12px;backdrop-filter:blur(1px);min-height:70px;display:flex;flex-direction:column;justify-content:center;transition:transform .18s ease,border-color .18s ease,background .18s ease}
.hi-eb-card:hover{transform:translateY(-1px);border-color:rgba(255,255,255,.24);background:rgba(255,255,255,.048)}
.hi-eb-k{font-size:11px;color:var(--ink2)}
.hi-eb-v{font-size:18px;font-weight:700;color:var(--ink1);margin-top:2px;letter-spacing:.2px}
.hi-eb-cert{font-size:13px;font-weight:600;color:var(--gold-l);margin-top:5px}
.hi-eb-progress{margin-top:10px;position:relative;z-index:1}
.hi-eb-progress-track{height:7px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid var(--border);overflow:hidden}
.hi-eb-progress-bar{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--teal),var(--green));box-shadow:0 0 12px rgba(16,185,129,.35);transition:width .22s ease}
.hi-eb-progress-bar:after{content:'';display:block;height:100%;width:36px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.52),transparent);opacity:.8;animation:hiEbShine 2.4s linear infinite}
.hi-eb-actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;position:relative;z-index:1}
.hi-eb-btn{position:relative;transition:transform .15s ease,filter .15s ease}
.hi-eb-btn:after{content:'↗';font-size:10px;opacity:.62;margin-left:6px}
.hi-eb-btn:hover{transform:translateY(-1px);filter:brightness(1.08)}
@keyframes hiEbShine{0%{transform:translateX(-50px)}100%{transform:translateX(230px)}}
.hi-inf-head-polish{padding:10px 12px;border:1px solid rgba(255,255,255,.1);border-radius:12px;background:linear-gradient(135deg,rgba(59,130,246,.08),rgba(16,185,129,.05))}
.hi-inf-badge-polish{background:rgba(59,130,246,.16);border:1px solid rgba(59,130,246,.34);padding:2px 8px;border-radius:999px}
.hi-inf-meta-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.hi-inf-formula-polish{margin:0;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:999px;padding:5px 10px}
.hi-inf-signal{font-size:10.5px;color:var(--gold-l);border:1px solid rgba(245,158,11,.38);background:rgba(245,158,11,.1);border-radius:999px;padding:4px 8px}
.hi-inf-signal.ready{color:var(--teal-l);border-color:rgba(16,185,129,.38);background:rgba(16,185,129,.1)}
.hi-inf-signal.cert{color:var(--green-l);border-color:rgba(34,197,94,.48);background:rgba(34,197,94,.14)}
.hi-btn-policy-hint-polish{border-color:rgba(255,255,255,.18);background:rgba(255,255,255,.04)}
.hi-audit-head-polish{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:8px 10px;border:1px solid var(--border);border-radius:10px;background:rgba(255,255,255,.03)}
.hi-audit-chip{font-size:10.5px;border-radius:999px;padding:3px 8px;border:1px solid rgba(148,163,184,.35);color:var(--ink2);background:rgba(148,163,184,.1)}
.hi-audit-chip.ok{border-color:rgba(34,197,94,.45);color:var(--green-l);background:rgba(34,197,94,.12)}
.hi-audit-chip.wait{border-color:rgba(245,158,11,.42);color:var(--gold-l);background:rgba(245,158,11,.12)}
.hi-res-header{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;text-align:center}
.hi-res-header-kicker{font-size:11px;color:var(--ink2);letter-spacing:.6px}
.hi-res-header-main{display:flex;align-items:baseline;gap:6px;line-height:1}
.hi-res-header-main strong{font-size:38px;letter-spacing:1.4px;color:var(--gold-l);text-shadow:0 0 18px rgba(245,158,11,.28);font-variant-numeric:tabular-nums}
.hi-res-header-main span{font-size:16px;color:var(--ink1)}
.hi-res-header-sub{font-size:11px;color:var(--ink2)}
.hi-kpi-tax-mega{font-size:42px;line-height:1.08;letter-spacing:1.6px;font-weight:800;color:#f8df95;text-shadow:0 0 22px rgba(245,158,11,.35),0 0 3px rgba(255,255,255,.2);font-variant-numeric:tabular-nums}
.hi-kpi-tax-mega[data-lcd='off']{color:var(--gold-l);opacity:.9}
.hi-m-inp-wrap{display:flex;align-items:center;gap:6px}
.hi-m-inp-wrap .hi-m-inp{flex:1;min-width:0}
.hi-m-bulb{width:24px;height:24px;border-radius:7px;border:1px solid rgba(245,158,11,.35);background:rgba(245,158,11,.12);color:var(--gold-l);font-size:12px;cursor:pointer;line-height:1;display:inline-flex;align-items:center;justify-content:center}
.hi-m-bulb:hover{filter:brightness(1.1);transform:translateY(-1px)}
@media (prefers-reduced-motion: reduce){
  .hi-eb,.hi-eb:before,.hi-eb-card,.hi-eb-btn,.hi-eb-action,.hi-eb-progress-bar{transition:none}
  .hi-eb-progress-bar:after{animation:none}
}
@media (max-width: 760px){
  .hi-eb{padding:12px}
  .hi-eb-v{font-size:16px}
  .hi-eb-action{width:100%;text-align:center}
  .hi-eb-actions .hi-tool-btn{flex:1 1 100%}
  .hi-inf-meta-row{align-items:stretch}
  .hi-res-header-main strong{font-size:30px}
  .hi-kpi-tax-mega{font-size:32px}
}
</style>
</head>
<body>
<div id="hi-suite" class="hi-warroom">
  <header class="hi-topbar hi-glass" aria-label="战情室顶栏">
    <div class="hi-brand">
      <div class="hi-enterprise-mark hi-enterprise-mark-btn" id="hi-enterprise-mark" title="点击查看主权认领档案" role="button" tabindex="0" aria-label="主权认领档案">
        <img class="hi-enterprise-logo" id="hi-enterprise-logo" alt="" hidden>
        <span class="hi-enterprise-logo-fb" id="hi-enterprise-logo-fb">企</span>
      </div>
      <div>
        <div class="hi-brand-title">原厂资产确权</div>
        <div class="hi-brand-en">ORIGIN ASSET ATTEST · PRODUCTION-SIDE FACTOR ISSUANCE</div>
      </div>
    </div>
    <div class="hi-sovereign-pill">
      <span>🛡️ 数据主权受控模式</span>
      <span class="hi-pulse-dot" aria-hidden="true"></span>
      <span class="hi-local-calc">本地计算中</span>
      <span class="hi-sovereignty-lamp" id="hi-sovereignty-lamp">🟡 检测中</span>
      <span class="hi-phase-tag" id="hi-phase-tag" title="HengAI 三阶段成长路径">Phase 2 · 工业原厂期</span>
    </div>
    <div class="hi-topbar-right">
      <button type="button" class="hi-bell" title="通知" aria-label="通知"><span class="hi-bell-ico">🔔</span><span class="hi-bell-badge" id="hi-notify-count" hidden>0</span></button>
      <div class="hi-topbar-user">
        <span class="hi-uavatar dyn-user-name-initial" data-state-bind="user.name" data-empty="?">?</span>
        <div>
          <div class="hi-uname"><span class="dyn-company-name" data-state-bind="company.name" data-empty="企业">企业</span> <span class="dyn-user-name" data-state-bind="user.name" data-empty=""></span></div>
          <div class="hi-urole">Lv.<span class="dyn-user-level" data-state-bind="user.currentLevel" data-empty="1">1</span> · <span class="dyn-user-tier" data-state-bind="user.tier" data-empty="—">—</span></div>
        </div>
      </div>
    </div>
  </header>

  <nav class="hi-context-trail hi-glass" id="hi-context-trail" hidden aria-label="产业链操作路径">
    <button type="button" class="hi-ctx-back" id="hi-ctx-back-supply">← 返回供应链协同 · 碳资产确权</button>
    <span class="hi-ctx-arrow" aria-hidden="true">→</span>
    <span class="hi-ctx-here">🛰️ 产业链主权共振 · 因子精算战情室</span>
    <span class="hi-ctx-hint">确权完成后可继续：邀请供应商 · 签发穿透卡片 · 批量协同</span>
  </nav>

  <section class="hi-claim-gate hi-glass" id="hi-claim-gate" hidden aria-label="主权认领引导">
    <div class="hi-claim-inner">
      <div class="hi-claim-seal" aria-hidden="true">CL-COP</div>
      <h2 class="hi-claim-title">主权认领 · 企业身份关联</h2>
      <p class="hi-claim-desc">检测到企业档案尚未完成主权关联。请先完成<strong>企业身份核验</strong>，再激活产业链诉求大盘与因子精算战情室。</p>

      <details class="hi-claim-help" open>
        <summary>ℹ️ 什么是《主权授权书》？</summary>
        <div class="hi-claim-help-body">
          <p><strong>定义：</strong>《CL-COP 产业链数据主权授权书》是企业法定代表人（或授权代理人）签发的<strong>书面授权文件</strong>，用于证明：当前操作人有权代表本企业在 HengAI 平台认领「工业原厂 · 因子精算」主权节点，并向产业链下游提供经脱敏的碳强度因子背书。</p>
          <p><strong>与保密承诺书的区别：</strong>底部《重工业核心数据保密承诺书》约束<strong>工序数据不离机</strong>；本授权书约束<strong>谁有权代表企业对外确权</strong>，二者缺一不可。</p>
          <p><strong>须包含要素（缺一不可）：</strong></p>
          <ul>
            <li>企业全称 + 统一社会信用代码（与上方填写一致）</li>
            <li>被授权人姓名、职务（如能源管理部负责人 / 碳管理经办人）</li>
            <li>授权范围：因子精算、CL-IVC 官方确权、核验池写入、产业链因子共享</li>
            <li>数据主权条款：工序级原始能耗仅存本地 LOCAL_VAULT，不上传云端</li>
            <li>企业公章（或合同专用章）+ 法定代表人/授权代理人签字 + 日期</li>
          </ul>
          <p><strong>可接受格式：</strong>盖章扫描件 PDF，或 JPG/PNG 高清照片（需四角完整、文字清晰）。<strong>不接受</strong>未盖章的 Word/txt 电子稿直接上传。</p>
          <p><strong>常见替代件：</strong>加盖公章的《授权委托书》+ 经办人身份证复印件（可拼在同一 PDF 内）。</p>
          <p class="hi-claim-help-note">📄 <strong>范本是什么？</strong>一份可直接交给法务审定、<strong>打印后由法定代表人签字并加盖企业公章</strong>的完整授权书草案（含鉴于、授权事项、数据主权条款、签章页），不是空文件或要点摘要。审定盖章后扫描为 PDF 再上传。</p>
          <p class="hi-claim-help-note">⚖️ 智能预审仅辅助比对名称/代码/签章，<strong>绝不自动通过</strong>；最终审核以 HEGC 人工核验为准。未盖章或涂改的电子稿将被驳回。</p>
        </div>
      </details>

      <form class="hi-claim-form" id="hi-claim-form">
        <label class="hi-claim-field">
          <span>统一社会信用代码</span>
          <input type="text" id="hi-claim-credit" class="hi-claim-inp" placeholder="91XXXXXXXXXXXXXXXX" maxlength="18" autocomplete="organization">
        </label>
        <label class="hi-claim-field">
          <span>企业全称</span>
          <input type="text" id="hi-claim-name" class="hi-claim-inp" placeholder="与营业执照一致" autocomplete="organization">
        </label>
        <label class="hi-claim-field">
          <span>上传《主权授权书》扫描件</span>
          <input type="file" id="hi-claim-auth" class="hi-claim-file" accept=".pdf,.png,.jpg,.jpeg">
          <span class="hi-claim-file-hint" id="hi-claim-file-hint">请上传盖章 PDF 或清晰照片 · 仅用于身份核验</span>
        </label>
        <button type="button" class="hi-claim-template" id="hi-btn-claim-template-doc">⬇️ 下载 Word 范本（.doc）</button>
        <button type="button" class="hi-claim-template" id="hi-btn-claim-template-pdf">⬇️ 下载 PDF 范本</button>
        <button type="button" class="hi-claim-template" id="hi-btn-claim-template">📄 在线预览 / 复制要点给法务</button>
        <button type="submit" class="hi-card-btn hi-card-gold hi-claim-submit">下一步 · 信息确认</button>
      </form>
    </div>
  </section>

  <div id="hi-warroom-main">
  <div class="hi-pending-banner hi-glass" id="hi-pending-banner" hidden role="status">
    <span>🟡 主权授权书<strong>人工审核中</strong>（通常 1–3 个工作日）· 可先使用战情室进行因子精算 · 点击左上角企业标识查看进度</span>
  </div>
  <section class="hi-resonance hi-glass" aria-label="产业链诉求大盘">
    <div class="hi-res-header" id="hi-res-header">
      <div class="hi-res-header-kicker">产业链确权诉求总量</div>
      <div class="hi-res-header-main"><strong class="hi-res-header-count" id="hi-resonance-req-count">0</strong><span>家</span></div>
      <div class="hi-res-header-sub">实时汇总来自下游成员的确权请求</div>
    </div>
    <div class="hi-res-section-title" id="hi-res-section-title">产业链诉求大盘</div>
    <div class="hi-res-grid">
      <div class="hi-kpi-block">
        <p class="hi-kpi-lead">当前产业链共有</p>
        <div class="hi-res-kpi-num hi-num-gold" id="hi-kpi-crusade-wrap">
          <span class="dyn-crusade-count" id="hi-kpi-crusade-display">0</span><span class="hi-res-unit" id="hi-kpi-crusade-unit">家</span>
        </div>
        <p class="hi-kpi-desc" id="hi-kpi-crusade-desc">配套中小企业申请您的碳因子背书</p>
        <p class="hi-delta hi-delta-up" id="hi-delta-crusade">较上月 +<span class="hi-delta-val" id="hi-delta-crusade-val">—</span> 家</p>
      </div>
      <div class="hi-kpi-block">
        <p class="hi-kpi-lead" id="hi-kpi-tax-lead">预计可为全产业链挽回</p>
        <div class="hi-res-kpi-num hi-num-gold dyn-tax-risk hi-kpi-tax-mega" id="hi-kpi-tax-display" data-lcd="off">€ 0</div>
        <p class="hi-kpi-desc" id="hi-kpi-tax-desc">的超额碳税损失</p>
        <p class="hi-delta hi-delta-up" id="hi-delta-tax">较上月增加 <span class="hi-delta-val" id="hi-delta-tax-val">—</span></p>
      </div>
      <div class="hi-kpi-block hi-kpi-hero">
        <div class="hi-motto-shield">
          <img class="hi-motto-visual hi-logo-clone" src="" alt="" aria-hidden="true">
          <div class="hi-motto-text">
            <p class="hi-motto-line">您的每一次确权</p>
            <p class="hi-motto-line">都是产业链绿色出海的</p>
            <p class="hi-motto-line hi-motto-accent">定海神针</p>
          </div>
        </div>
      </div>
      <div class="hi-donut-block" id="hi-donut-block">
        <div class="hi-res-kpi-label">诉求行业分布</div>
        <div class="hi-donut-wrap">
          <svg class="hi-donut-svg" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="44" fill="none" stroke="var(--border)" stroke-width="14"/>
            <circle id="hi-donut-steel" cx="60" cy="60" r="44" fill="none" stroke="var(--blue-l)" stroke-width="14" stroke-dasharray="0 276" transform="rotate(-90 60 60)"/>
            <circle id="hi-donut-al" cx="60" cy="60" r="44" fill="none" stroke="var(--gold-l)" stroke-width="14" stroke-dasharray="0 276" transform="rotate(-90 60 60)"/>
            <circle id="hi-donut-cement" cx="60" cy="60" r="44" fill="none" stroke="var(--teal-l)" stroke-width="14" stroke-dasharray="0 276" transform="rotate(-90 60 60)"/>
          </svg>
          <ul class="hi-donut-legend">
            <li><span class="hi-leg-dot steel"></span>钢铁行业 <strong id="hi-leg-steel">—</strong></li>
            <li><span class="hi-leg-dot al"></span>铝业行业 <strong id="hi-leg-al">—</strong></li>
            <li><span class="hi-leg-dot cement"></span>水泥行业 <strong id="hi-leg-cement">—</strong></li>
          </ul>
        </div>
      </div>
      <div class="hi-honor-block" id="hi-honor-block">
        <div class="hi-honor-badge" id="hi-honor-badge">
          <img class="hi-honor-logo hi-logo-clone" src="" alt="" width="44" height="44">
          <div>
            <div class="hi-honor-title">CL-Origin 绿色出海先行者</div>
            <div class="hi-honor-done" id="hi-honor-status">待首次确权解锁</div>
          </div>
        </div>
        <button type="button" class="hi-honor-btn" id="hi-btn-honor-wall">荣誉墙</button>
      </div>
    </div>
  </section>

  <section class="hi-glass hi-eb" id="hi-exec-brief" aria-label="执行总览">
    <div class="hi-eb-head">
      <div>
        <div class="hi-eb-title">执行总览 · 原厂资产确权战情卡</div>
