          <circle cx="80" cy="80" r="62" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="10"/>
          <circle id="hi-ring-arc" cx="80" cy="80" r="62" fill="none" stroke="url(#hiRingGrad)" stroke-width="10" stroke-linecap="round" stroke-dasharray="0 390" transform="rotate(-90 80 80)"/>
          <defs>
            <linearGradient id="hiRingGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="var(--green)"/>
              <stop offset="100%" stop-color="var(--gold)"/>
