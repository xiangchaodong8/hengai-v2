  document.getElementById('hi-btn-policy-hint').addEventListener('click', scrollToPolicyCard);
  document.getElementById('hi-policy-to-budget').addEventListener('click', exportBudgetReportPdf);
  document.getElementById('hi-btn-history').addEventListener('click', showHistory);

  function bindHonorBadge() {
    var show = false;
    if (window.AppState && window.AppState.badges) {
      show = window.AppState.badges.some(function (b) {
        return (b.badgeCode || b.badge_code || '') === 'CL-ORIGIN-PIONEER';
      });
    }
    var st = document.getElementById('hi-honor-status');
    var badge = document.getElementById('hi-honor-badge');
    if (st) st.textContent = show ? '首次确权完成' : '待首次确权解锁';
    if (badge) badge.classList.toggle('hi-honor-on', show);
  }

  function bindAppState(fromRemote) {
    if (fromRemote) {
      resonanceServer = null;
      var m = window.AppState && window.AppState.metrics;
      if (m && window.AppState.patchState) {
        window.AppState.patchState({
          industryAudit: Object.assign({}, window.AppState.industryAudit || {}, {
            resonanceServerCrusade: Number(m.crusadeCount) || 0,
            resonanceServerTax: Number(m.totalTaxPenalty) || Number(m.total_tax_penalty) || 0,
          }),
        }, { emitStateSynced: false });
      }
    }
    if (typeof syncAppState === 'function' && window.AppState) {
      syncAppState(window.AppState, { emitStateSynced: false });
    }
    captureResonanceServer(true);
    const co = window.AppState && window.AppState.company;
    if (co && co.verifiedFactor != null) {
      document.getElementById('hi-prev-ci').value = co.verifiedFactor;
    }
    const ia = window.AppState && window.AppState.industryAudit;
    if (ia && ia.localCarbonIntensity > 0) updateGauge(ia.localCarbonIntensity);
    var res = readMatrix(activeIndustry, (INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel).steps);
    if (res.ci > 0) {
      updateResonanceDashboard(res.ci, res.totalOut);
    } else if (lastResonanceProjection && lastResonanceProjection.projected) {
      paintResonanceKpis(lastResonanceProjection);
      renderAuditLog(0);
    } else {
      updateResonanceDashboard(0, 0);
    }
    applySovereigntyGate();
    applyIndustryScope();
    refreshRegionalPolicy();
    bindHonorBadge();
    bindEnterpriseLogo();
    refreshResonanceHeader();
    updateDonut();
    renderInfluenceRank(activeIndustry, false);
    applyEmpowermentUI();
  }

  function clearLocalIndustry() {
    var prefix = activeIndustry + ':';
    Object.keys(LOCAL_VAULT).forEach(function (k) {
      if (k.indexOf(prefix) === 0) delete LOCAL_VAULT[k];
    });
    mountMatrix(activeIndustry, INDUSTRY_META[activeIndustry]);
    localCalc();
    updateResonanceDashboard(0, 0);
    saveLocalVault();
    if (typeof showToast === 'function') showToast('已清空当前行业 LOCAL_VAULT');
  }

  document.getElementById('hi-btn-clear-local').addEventListener('click', clearLocalIndustry);
  document.getElementById('hi-btn-pledge-sign').addEventListener('click', function () {
    document.getElementById('hi-pledge').classList.add('show');
  });
  document.getElementById('hi-btn-honor-wall').addEventListener('click', function () {
    if (typeof showToast === 'function') showToast('荣誉墙 · 请在全域中心「荣誉体系」查看');
    else window.open('HengAI_荣誉体系.html', '_blank');
  });
  document.getElementById('hi-suite').addEventListener('click', function (e) {
    var btn = e.target && e.target.closest && e.target.closest('.hi-col-calc');
    if (btn) localCalc();
  });

  var monthInp = document.getElementById('hi-report-month');
  if (monthInp) monthInp.value = new Date().toISOString().slice(0, 7);

  var claimForm = document.getElementById('hi-claim-form');
  if (claimForm) claimForm.addEventListener('submit', submitSovereigntyClaim);
  var claimTplDoc = document.getElementById('hi-btn-claim-template-doc');
  if (claimTplDoc) claimTplDoc.addEventListener('click', function () { downloadSovereigntyTemplate('doc'); });
  var claimTplPdf = document.getElementById('hi-btn-claim-template-pdf');
  if (claimTplPdf) claimTplPdf.addEventListener('click', function () { downloadSovereigntyTemplate('pdf'); });
  var claimTplBtn = document.getElementById('hi-btn-claim-template');
  if (claimTplBtn) {
    claimTplBtn.addEventListener('click', function () {
      previewSovereigntyTemplate();
    });
  }
  var confirmBack = document.getElementById('hi-modal-confirm-back');
  if (confirmBack) confirmBack.addEventListener('click', function () { closeCommerceModal('hi-modal-claim-confirm'); });
  var confirmAgree = document.getElementById('hi-confirm-agree');
  var confirmSubmit = document.getElementById('hi-modal-confirm-submit');
  if (confirmAgree && confirmSubmit) {
    confirmAgree.addEventListener('change', function () { confirmSubmit.disabled = !confirmAgree.checked; });
    confirmSubmit.addEventListener('click', executeSovereigntyClaimSubmit);
  }
  var successOk = document.getElementById('hi-modal-success-ok');
  if (successOk) successOk.addEventListener('click', function () {
    enterWarRoomAfterClaim();
  });
  var entMark = document.getElementById('hi-enterprise-mark');
  if (entMark) {
    entMark.addEventListener('click', function () {
      renderSovereigntyDossier();
      openCommerceModal('hi-modal-sovereignty-dossier');
    });
    entMark.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        renderSovereigntyDossier();
        openCommerceModal('hi-modal-sovereignty-dossier');
      }
    });
  }
  var dossierLogout = document.getElementById('hi-dossier-logout');
  if (dossierLogout) dossierLogout.addEventListener('click', hiDoLogout);
  var dossierCloseBtn = document.getElementById('hi-dossier-close-btn');
  if (dossierCloseBtn) dossierCloseBtn.addEventListener('click', closeSovereigntyDossier);
  var dossierCloseX = document.getElementById('hi-dossier-close-x');
  if (dossierCloseX) dossierCloseX.addEventListener('click', closeSovereigntyDossier);
  var goldenSealOk = document.getElementById('hi-golden-seal-ok');
  if (goldenSealOk) goldenSealOk.addEventListener('click', closeGoldenSealCeremony);
  wireCommerceModalDismiss();
  var dossierTpl = document.getElementById('hi-dossier-dl-template');
  if (dossierTpl) dossierTpl.addEventListener('click', function () { downloadSovereigntyTemplate('doc'); });
  var dossierView = document.getElementById('hi-dossier-view-doc');
  if (dossierView) {
    dossierView.addEventListener('click', async function () {
      try {
        var t = typeof getToken === 'function' ? getToken() : (localStorage.getItem('hengai_token') || '');
        var headers = t ? { Authorization: 'Bearer ' + t } : {};
        var res = await fetch(apiBase() + '/api/v1/hub/sovereignty-claim/document', { credentials: 'include', headers: headers });
        if (!res.ok) throw new Error('无法获取文件');
        var blob = await res.blob();
        var url = URL.createObjectURL(blob);
        window.open(url, '_blank');
      } catch (err) {
        if (typeof showToast === 'function') showToast((err && err.message) || '打开失败');
      }
    });
  }
  var tplClose = document.getElementById('hi-modal-template-close');
  if (tplClose) tplClose.addEventListener('click', function () { closeCommerceModal('hi-modal-claim-template'); });
  var tplCopy = document.getElementById('hi-modal-template-copy');
  if (tplCopy) {
    tplCopy.addEventListener('click', function () {
      var pre = document.getElementById('hi-claim-template-text');
      var txt = pre ? pre.textContent : '';
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(txt).then(function () {
          if (typeof showToast === 'function') showToast('范本要点已复制 · 可粘贴至 Word 给法务排版');
        });
      } else if (typeof showToast === 'function') showToast('请手动选中范本文本复制');
    });
  }
  var claimFile = document.getElementById('hi-claim-auth');
  if (claimFile) {
    claimFile.addEventListener('change', function () {
      var hint = document.getElementById('hi-claim-file-hint');
      if (hint && claimFile.files && claimFile.files[0]) {
        hint.textContent = '✓ 已选择：' + claimFile.files[0].name;
      }
    });
  }

  if (window.EventBus && typeof window.EventBus.on === 'function') {
    window.EventBus.on('STATE_SYNCED', function () { bindAppState(true); });
    window.EventBus.on('STATE_UPDATED', function () {
      if (lastResonanceProjection && lastResonanceProjection.projected) {
        paintResonanceKpis(lastResonanceProjection);
      }
    });
  }
  function refreshHiContextTrail() {
    var trail = document.getElementById('hi-context-trail');
    var backBtn = document.getElementById('hi-ctx-back-supply');
    if (!trail || !backBtn) return;
    var fromSupply = false;
    try {
      var params = new URLSearchParams(location.search);
      if (params.get('from') === 'supply') fromSupply = true;
      if (sessionStorage.getItem('hengai_resonance_from') === 'supply') fromSupply = true;
    } catch (_) {}
    trail.hidden = !fromSupply;
  }

  function initHiContextTrail() {
    var backBtn = document.getElementById('hi-ctx-back-supply');
    if (!backBtn || backBtn.__bound) return;
    backBtn.__bound = true;
    refreshHiContextTrail();
    backBtn.addEventListener('click', function () {
      if (typeof window.returnToSupplyFromResonance === 'function') {
        window.returnToSupplyFromResonance();
        return;
      }
      try { sessionStorage.removeItem('hengai_resonance_from'); } catch (_) {}
      if (window.parent && window.parent !== window && typeof window.parent.navTo === 'function') {
        var nav = window.parent.document.getElementById('nav-supply');
        window.parent.navTo('supply', nav);
        return;
      }
      window.location.href = typeof window.hengaiPage === 'function'
        ? window.hengaiPage('HengAI_供应链协同.html')
        : 'HengAI_供应链协同.html';
    });
    window.addEventListener('message', function (e) {
      if (e.data && e.data.type === 'HENGAI_RESONANCE_FROM_SUPPLY') refreshHiContextTrail();
    });
    document.addEventListener('visibilitychange', function () {
      if (!document.hidden) refreshHiContextTrail();
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    if (typeof window.guardOriginFactoryPage === 'function') window.guardOriginFactoryPage();
    initHiContextTrail();
    var plEl = document.getElementById('hi-production-line');
    if (plEl) {
      try {
        var savedLine = sessionStorage.getItem(PROD_LINE_KEY);
        if (savedLine) plEl.value = savedLine;
      } catch (_) {}
      plEl.addEventListener('change', persistProductionLine);
      plEl.addEventListener('blur', persistProductionLine);
    }
    buildIndustryTabs();
    var initInd = getCompanyIndustryKey() ||
      ((window.HI_INDUSTRY_ORDER && window.HI_INDUSTRY_ORDER[0]) || 'steel');
    switchIndustry(initInd);
    refreshRegionalPolicy();
    bindEnterpriseLogo();
    applySovereigntyGate();
    renderAuditLog(0);
    bindAppState(false);
    updateDonut();
    renderInfluenceRank('steel', false);
    applyEmpowermentUI();
  });
  if (window.AppState) {
    applySovereigntyGate();
    bindAppState(false);
  } else {
    applySovereigntyGate();
    applyEmpowermentUI();
  }
  window.refreshResonanceHeader = refreshResonanceHeader;
  window.updateResonanceDashboard = updateResonanceDashboard;
})();
</script>
</body>
</html>
