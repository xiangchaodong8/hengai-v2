被授权人：________________  职务：________________

授权事项：
1. 代表本企业在 HengAI 平台认领「工业原厂 · 因子精算」主权节点；
2. 开展工序矩阵本地精算、CL-IVC 官方因子确权及核验池存证；
3. 向产业链下游提供经脱敏的单位产品碳强度及同比增减率。

数据主权声明：
工序级原始能耗绝对值仅保存在授权方本地终端（LOCAL_VAULT），不上传至 HengAI 云端。

授权期限：自 ____年__月__日起至 ____年__月__日止。

授权方（盖章）：________________
法定代表人/授权代理人（签字）：________________
日期：____年__月__日</pre>
      <p class="hi-claim-template-foot">ℹ️ 以上为要点范本，正式文本请以贵司法务部门审定版本为准。盖章扫描后上传 PDF 或照片即可。</p>
      <div class="hi-commerce-actions">
        <button type="button" class="hi-card-btn hi-card-muted" id="hi-modal-template-close">关闭</button>
        <button type="button" class="hi-card-btn hi-card-gold" id="hi-modal-template-copy">复制范本要点</button>
      </div>
    </div>
  </div>

  <div class="hi-commerce-modal" id="hi-modal-convert" role="dialog" aria-modal="true" hidden>
    <div class="hi-commerce-box hi-glass">
      <h2>ℹ️ 正式确权确认</h2>
      <p>正式确权需启动 <strong>CL-IVC 官方认证通道</strong>，费用将包含在「产业链合规赋能专项服务」中。</p>
      <p class="hi-convert-advice">💡 专业建议：建议先导出<strong>《合规资产确权与投资评价报告》</strong>呈送财务审批，内含政策补贴对冲指引与下游合规压力数据。</p>
      <ul class="hi-commerce-list">
        <li id="hi-convert-coverage-li">预计覆盖下游企业：<strong id="hi-convert-coverage">0</strong> 家</li>
        <li id="hi-convert-fee-li">专项服务费（示意）：<strong id="hi-convert-fee">—</strong></li>
        <li>工序级原始数据仍仅存 LOCAL_VAULT，不上传服务器</li>
      </ul>
      <div class="hi-commerce-actions hi-commerce-actions-col">
        <button type="button" class="hi-card-btn hi-card-budget" id="hi-modal-convert-budget">📄 先导出投资评价报告</button>
        <button type="button" class="hi-card-btn hi-card-gold" id="hi-modal-convert-ok">继续启动认证通道</button>
        <button type="button" class="hi-card-btn hi-card-muted" id="hi-modal-convert-cancel">稍后再说</button>
      </div>
    </div>
  </div>
  <div id="hi-press-fx" class="hi-press-fx" aria-hidden="true" hidden>
    <div class="hi-press-machine">
      <div class="hi-press-plate"></div>
      <div class="hi-press-stamp" id="hi-press-stamp">SOVEREIGN<br>SEAL</div>
    </div>
  </div>

  <div class="hi-golden-seal-modal" id="hi-golden-seal-modal" role="dialog" aria-modal="true" hidden>
    <div class="hi-golden-seal-backdrop"></div>
    <div class="hi-golden-seal-stage">
      <div class="hi-golden-seal-glow" aria-hidden="true"></div>
      <div class="hi-golden-seal-coin" id="hi-golden-seal-coin">
        <div class="hi-golden-seal-ring"></div>
        <div class="hi-golden-seal-core">
          <span class="hi-golden-seal-label">CL-COP</span>
          <strong class="hi-golden-seal-id" id="hi-golden-seal-id">—</strong>
          <span class="hi-golden-seal-vcode" id="hi-golden-seal-vcode">GTCID —</span>
          <span class="hi-golden-seal-sub">产业链数据主权 · 官方钢印</span>
        </div>
      </div>
      <h2 class="hi-golden-seal-title">确权合闸 · 钢印加冕</h2>
      <p class="hi-golden-seal-desc">单位产品碳强度已存入核验池。下游配套企业的惩罚溢价将随刷新同步解除。</p>
      <button type="button" class="hi-card-btn hi-card-gold" id="hi-golden-seal-ok">完成</button>
    </div>
  </div>

  <div class="hi-pledge" id="hi-pledge" role="dialog" aria-modal="true">
    <div class="hi-pledge-box hi-glass">
      <h2>《重工业核心数据保密承诺书》</h2>
      <p>本人/本企业确认：工序级原始能耗绝对值仅保存在本终端 LOCAL_VAULT，不上传至 HengAI 云端。</p>
      <p>向平台同步的数据仅限于：<strong>单位产品碳强度</strong>、<strong>同比增减率</strong>及行业/product 脱敏标签。</p>
      <p>本人对数据真实性负责，并授权 HengAI 生成 CL-COP 系列确权编号供产业链引用。</p>
      <div class="hi-pledge-actions">
        <button type="button" class="hi-card-btn hi-card-muted" id="hi-pledge-cancel">取消</button>
        <button type="button" class="hi-card-btn hi-card-gold" id="hi-pledge-ok">我已阅读并承诺</button>
      </div>
    </div>
  </div>
  <div id="hi-pdf-root"></div>
</div>
<script>
(function () {
  'use strict';

  const LOCAL_VAULT = {};
  const VAULT_STORAGE_KEY = 'hengai_hi_local_vault_v1';
  const PROD_LINE_KEY = 'hengai_hi_production_line';

  function saveLocalVault() {
    try { sessionStorage.setItem(VAULT_STORAGE_KEY, JSON.stringify(LOCAL_VAULT)); } catch (_) {}
  }

  function loadLocalVault() {
    try {
      var raw = sessionStorage.getItem(VAULT_STORAGE_KEY);
      if (!raw) return;
      var parsed = JSON.parse(raw);
      if (parsed && typeof parsed === 'object') {
        Object.keys(parsed).forEach(function (k) { LOCAL_VAULT[k] = parsed[k]; });
      }
    } catch (_) {}
  }

  function getProductionLine() {
    var el = document.getElementById('hi-production-line');
    var v = el && el.value ? el.value.trim() : '';
    if (!v) {
      try { v = sessionStorage.getItem(PROD_LINE_KEY) || 'L01'; } catch (_) { v = 'L01'; }
    }
    return v.toUpperCase();
  }

  function persistProductionLine() {
    var el = document.getElementById('hi-production-line');
    if (!el) return;
    try { sessionStorage.setItem(PROD_LINE_KEY, getProductionLine()); } catch (_) {}
  }

  loadLocalVault();
  const CIRC = 2 * Math.PI * 44;
  const RING_CIRC = 2 * Math.PI * 62;
  let ringMax = 3.5;

  function blueprintToMeta(bp) {
    if (!bp) return null;
    return {
      code: bp.code,
      steps: bp.steps.map(function (s) {
        return [s.name, s.defaults.ef, s.defaults.energy, s.icon];
      }),
      panel: 'hi-panel-dynamic',
      flow: 'hi-flow-dynamic',
      head: 'hi-head-dynamic',
      body: 'hi-body-dynamic',
      title: bp.title,
      sub: bp.sub,
      bench: bp.bench,
      best: bp.best,
      ringMax: bp.ringMax,
      productLabel: bp.productLabel,
      unitLabel: bp.unitLabel,
      unitRing: bp.unitRing,
      calcMode: bp.calcMode || 'standard',
      coreKpis: bp.coreKpis || [],
      gdEts: bp.gdEts !== false,
      cbamExpandWarning: !!bp.cbamExpandWarning,
      intensityUnit: bp.intensityUnit || 'tCO2e/t',
      kpi: bp.kpi,
    };
  }

  function buildIndustryMetaFromBlueprint() {
    var bpRoot = window.HI_INDUSTRY_BLUEPRINT || {};
    var order = window.HI_INDUSTRY_ORDER || Object.keys(bpRoot);
    var meta = {};
    order.forEach(function (k) {
      if (bpRoot[k]) meta[k] = blueprintToMeta(bpRoot[k]);
    });
    return meta;
  }

  const INDUSTRY_META = buildIndustryMetaFromBlueprint();
  ringMax = (INDUSTRY_META.steel && INDUSTRY_META.steel.ringMax) || 3.5;

  const INDUSTRY_CODE_MAP = {
    steel: 'steel', '钢铁': 'steel', steel_mill: 'steel',
    cement: 'cement', '水泥': 'cement', '水泥业': 'cement',
    petro: 'petro', petrochemical: 'petro', '石化': 'petro', '化工': 'petro',
    paper: 'paper', papermaking: 'paper', '造纸': 'paper',
    aviation: 'aviation', '民航': 'aviation', airline: 'aviation',
    ceramic: 'ceramic', ceramics: 'ceramic', '陶瓷': 'ceramic',
    port: 'port', ports: 'port', '港口': 'port', '交通': 'port',
    idc: 'idc', datacenter: 'idc', '数据中心': 'idc',
    aluminum: 'steel', aluminium: 'steel', al: 'steel', '铝': 'steel', '铝业': 'steel',
  };
  const INDUSTRY_DISPLAY = {};
  Object.keys(INDUSTRY_META).forEach(function (k) {
    var bp = (window.HI_INDUSTRY_BLUEPRINT || {})[k];
    INDUSTRY_DISPLAY[k] = (bp && bp.display) || k;
  });
  const INFLUENCE_LABELS = {};
  Object.keys(INDUSTRY_META).forEach(function (k) {
    INFLUENCE_LABELS[k] = (INDUSTRY_DISPLAY[k] || k) + '行业榜';
  });

  function buildIndustryTabs() {
    var host = document.getElementById('hi-ind-tabs-host');
    if (!host) return;
    host.innerHTML = '';
    var order = window.HI_INDUSTRY_ORDER || Object.keys(INDUSTRY_META);
    order.forEach(function (key, i) {
      if (!INDUSTRY_META[key]) return;
      var bp = (window.HI_INDUSTRY_BLUEPRINT || {})[key] || {};
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'hi-tab' + (i === 0 ? ' on' : '');
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      btn.setAttribute('data-ind', key);
      btn.textContent = bp.shortLabel || bp.display || key;
      btn.title = bp.title || key;
      host.appendChild(btn);
    });
    host.querySelectorAll('.hi-tab').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var ind = btn.getAttribute('data-ind') || 'steel';
        var scoped = getCompanyIndustryKey();
        if (scoped && ind !== scoped) return;
        switchIndustry(ind);
      });
    });
  }

  function isGuangdongEnterprise() {
    var co = (window.AppState && window.AppState.company) || {};
    var tag = String(co.regionTag || co.region_tag || '').toLowerCase();
    if (/gd|guangdong|广东/.test(tag)) return true;
    return false;
  }

  function refreshRegionalPolicy() {
    var gd = isGuangdongEnterprise();
    var meta = INDUSTRY_META[activeIndustry] || {};
    var gdBanner = document.getElementById('hi-gd-ets-banner');
    var gdHint = document.getElementById('hi-gd-sync-hint');
    if (gdBanner) gdBanner.hidden = !(gd && meta.gdEts);
    if (gdHint) gdHint.hidden = !gd;
  }

  function refreshCbamExpandWarning() {
    var meta = INDUSTRY_META[activeIndustry] || {};
    var el = document.getElementById('hi-cbam-expand-warn');
    if (el) el.hidden = !meta.cbamExpandWarning;
  }

  function refreshIndustryKpiStrip(meta) {
    meta = meta || INDUSTRY_META[activeIndustry] || {};
    var strip = document.getElementById('hi-ind-kpi-strip');
    if (!strip) return;
    if (!meta.coreKpis || !meta.coreKpis.length) {
      strip.hidden = true;
      return;
    }
    strip.hidden = false;
    strip.innerHTML = meta.coreKpis.map(function (k) {
      return '<span>核心 KPI · ' + k + '</span>';
    }).join('') + (meta.kpi ? '<span>行业 KPI · ' + meta.kpi + '</span>' : '');
  }

  function getMatrixRowDefs(meta) {
    meta = meta || INDUSTRY_META[activeIndustry] || {};
    if (meta.calcMode === 'idc') {
      return [
        { cls: 'hi-m-out', label: 'IT负载 (MWh)', field: 'output', ph: 'MWh', inp: true },
        { cls: 'hi-m-energy', label: '辅助能耗系数', field: 'energy', ph: '系数', inp: true, defIdx: 2 },
        { cls: 'hi-m-ef', label: '电网因子 (tCO₂e/MWh)', field: 'ef', ph: '因子', inp: true, defIdx: 1 },
        { cls: 'hi-m-emit', label: '碳排放量 (tCO₂e)', field: 'emit', ph: '', inp: false },
      ];
    }
    if (meta.calcMode === 'rtk') {
      return [
        { cls: 'hi-m-out', label: '运量 (吨公里 RTK)', field: 'output', ph: 'RTK', inp: true },
        { cls: 'hi-m-energy', label: '航油消耗 (t/RTK)', field: 'energy', ph: 't/RTK', inp: true, defIdx: 2 },
        { cls: 'hi-m-ef', label: '排放因子 (tCO₂e/t油)', field: 'ef', ph: '因子', inp: true, defIdx: 1 },
        { cls: 'hi-m-emit', label: '碳排放量 (tCO₂e)', field: 'emit', ph: '', inp: false },
      ];
    }
    if (meta.calcMode === 'teu') {
      return [
        { cls: 'hi-m-out', label: '吞吐量 (TEU)', field: 'output', ph: 'TEU', inp: true },
        { cls: 'hi-m-energy', label: '单箱能耗 (GJ/TEU)', field: 'energy', ph: 'GJ/TEU', inp: true, defIdx: 2 },
        { cls: 'hi-m-ef', label: '碳排放因子 (tCO₂e/GJ)', field: 'ef', ph: '因子', inp: true, defIdx: 1 },
        { cls: 'hi-m-emit', label: '碳排放量 (tCO₂e)', field: 'emit', ph: '', inp: false },
      ];
    }
    if (meta.calcMode === 'area') {
      return [
        { cls: 'hi-m-out', label: '产量 (㎡)', field: 'output', ph: '㎡', inp: true },
        { cls: 'hi-m-energy', label: '单耗 (GJ/㎡)', field: 'energy', ph: 'GJ/㎡', inp: true, defIdx: 2 },
        { cls: 'hi-m-ef', label: '碳排放因子 (tCO₂e/GJ)', field: 'ef', ph: '因子', inp: true, defIdx: 1 },
        { cls: 'hi-m-emit', label: '碳排放量 (tCO₂e)', field: 'emit', ph: '', inp: false },
      ];
    }
    return [
      { cls: 'hi-m-out', label: '产量（吨）', field: 'output', ph: 't', inp: true },
      { cls: 'hi-m-energy', label: '综合能耗（GJ/吨）', field: 'energy', ph: 'GJ/t', inp: true, defIdx: 2 },
      { cls: 'hi-m-ef', label: '碳排放因子（tCO₂e/GJ）', field: 'ef', ph: '因子', inp: true, defIdx: 1 },
      { cls: 'hi-m-emit', label: '碳排放量（tCO₂e）', field: 'emit', ph: '', inp: false },
    ];
  }

  const INDUSTRY_CRUSADE_SHARE = {
    steel: 0.22, cement: 0.12, petro: 0.18, paper: 0.10, aviation: 0.08,
    ceramic: 0.10, port: 0.08, idc: 0.12,
  };
  const INDUSTRY_TAX_SHARE = INDUSTRY_CRUSADE_SHARE;

  function buildInfluenceEntries(ind) {
    var st = window.AppState || {};
    var pending = Number(st.resonance && st.resonance.pendingRequestsForIndustry) ||
      Number(st.metrics && st.metrics.resonanceCount) ||
      Number(st.metrics && st.metrics.crusadeCount) || 0;
    var taxBase = Number(st.metrics && st.metrics.totalTaxPenalty) ||
      Number(st.industryAudit && st.industryAudit.totalTaxPenaltyEur) || 0;
    // 保持排行榜在冷启动阶段也有可读内容，避免整块空白。
    if (pending <= 0) {
      var baselineTaxByIndustry = {
        steel: 420000, cement: 210000, petro: 380000, paper: 180000,
        aviation: 520000, ceramic: 240000, port: 160000, idc: 290000,
      };
      var baseTax = Math.max(taxBase * 0.18, baselineTaxByIndustry[ind] || 180000);
      var baseline = [];
      for (var b = 0; b < 5; b++) {
        baseline.push({
          alias: '行业基准企业 #' + String(200 + b),
          tag: '基准样本',
          empower: Math.max(1, 8 - b),
          taxSaved: Math.max(0, Math.round(baseTax * (0.35 - b * 0.05))),
          confidence: Math.max(70, 90 - b * 4),
          eis: Math.max(56, 88 - b * 5),
        });
      }
      return baseline;
    }
    var out = [];
    for (var i = 0; i < Math.min(7, pending); i++) {
      out.push({
        alias: '产业链成员 #' + String(1000 + i),
        tag: '#R' + String(1000 + i),
        empower: Math.max(1, Math.round(pending * (0.22 - i * 0.025))),
        taxSaved: Math.max(0, Math.round(taxBase * (0.18 - i * 0.02))),
        confidence: Math.max(72, 96 - i * 4),
        eis: Math.max(55, 92 - i * 5),
      });
    }
    return out;
  }

  function getCompanyIndustryKey() {
    if (sovereigntyMode === 'claim') return null;
    var co = window.AppState && window.AppState.company || {};
    var raw = String(
      co.industryCode || co.industry_code || co.industry || co.industryLabel || 'steel'
    ).trim().toLowerCase();
    if (INDUSTRY_CODE_MAP[raw]) return INDUSTRY_CODE_MAP[raw];
    return INDUSTRY_META[raw] ? raw : 'steel';
  }

  function industryMetricShare(ind, kind) {
    var table = kind === 'tax' ? INDUSTRY_TAX_SHARE : INDUSTRY_CRUSADE_SHARE;
    var scoped = getCompanyIndustryKey();
    if (scoped && ind !== scoped) return 0;
    if (scoped) return table[scoped] || 0.33;
    return table[ind] || 0.33;
  }

  function resolveWorkspaceIndustryKey() {
    var co = window.AppState && window.AppState.company || {};
    var raw = String(
      co.industryCode || co.industry_code || co.industry || co.industryLabel || 'steel'
    ).trim().toLowerCase();
    if (INDUSTRY_CODE_MAP[raw]) return INDUSTRY_CODE_MAP[raw];
    return INDUSTRY_META[raw] ? raw : 'steel';
  }

  function applyIndustryScope() {
    var scoped = getCompanyIndustryKey();
    var tabsWrap = document.querySelector('#hi-suite .hi-ind-tabs');
    document.querySelectorAll('#hi-suite .hi-tab').forEach(function (btn) {
      var ind = btn.getAttribute('data-ind');
      var show = !scoped || ind === scoped;
      btn.hidden = !show;
      btn.style.display = show ? '' : 'none';
    });
    if (tabsWrap) tabsWrap.classList.toggle('hi-ind-tabs-single', !!scoped);

    Object.keys(INDUSTRY_META).forEach(function (k) {
      var p = document.getElementById(INDUSTRY_META[k].panel);
      if (!p) return;
      p.hidden = false;
      p.classList.toggle('hi-panel-on', !scoped || k === scoped);
    });

    if (scoped && activeIndustry !== scoped) switchIndustry(scoped);

    var tmplHint = document.getElementById('hi-industry-template-hint');
    if (!tmplHint) {
      tmplHint = document.createElement('div');
      tmplHint.id = 'hi-industry-template-hint';
      tmplHint.style.cssText = 'font-size:10.5px;color:var(--ink2);margin-top:4px;line-height:1.5';
      var brand = document.querySelector('.hi-brand');
      if (brand) brand.appendChild(tmplHint);
    }
    if (tmplHint) {
      if (scoped) {
        var metaT = INDUSTRY_META[scoped] || INDUSTRY_META.steel;
        tmplHint.textContent = '行业感知：已加载「' + (INDUSTRY_DISPLAY[scoped] || scoped) + '」模板 · ' + metaT.sub;
      } else {
        tmplHint.textContent = '八大高耗能行业全光谱 · 切换 Tab 加载物理工序模型（GD-ETS 2026 对齐）';
      }
    }

    var resTitle = document.getElementById('hi-res-section-title');
    if (resTitle) {
      resTitle.textContent = scoped
        ? (INDUSTRY_DISPLAY[scoped] || '') + '产业链诉求大盘'
        : '产业链诉求大盘';
    }
    var crusadeDesc = document.getElementById('hi-kpi-crusade-desc');
    if (crusadeDesc) {
      crusadeDesc.textContent = scoped
        ? (INDUSTRY_DISPLAY[scoped] || '本行业') + '配套中小企业申请您的碳因子背书'
        : '配套中小企业申请您的碳因子背书';
    }
    var taxDesc = document.getElementById('hi-kpi-tax-desc');
    if (taxDesc) {
      taxDesc.textContent = scoped
        ? '预计本行业可挽回的超额碳税损失'
        : '的超额碳税损失';
    }
    var taxLead = document.getElementById('hi-kpi-tax-lead');
    if (taxLead) {
      taxLead.textContent = scoped ? '预计本行业可挽回' : '预计可为全产业链挽回';
    }

    document.querySelectorAll('.hi-donut-legend li').forEach(function (li) {
      var ind = li.getAttribute('data-ind');
      li.hidden = !!(scoped && ind && ind !== scoped);
    });
    var donutBlock = document.getElementById('hi-donut-block');
    if (donutBlock) donutBlock.hidden = !!scoped;

    var infTitle = document.querySelector('.hi-inf-title');
    if (infTitle && scoped) {
      infTitle.textContent = (INDUSTRY_DISPLAY[scoped] || '') + '行业 · 影响力排行榜';
    }
  }

  function refreshWarroomPhaseTag() {
    var el = document.getElementById('hi-phase-tag');
    if (!el) return;
    var co = window.AppState && window.AppState.company || {};
    var st = sovereigntyClaimStatus();
    var hasEnterprise = !!(co && (co.isComplete || co.is_complete || co.name));
    if (hasEnterprise || st === 'pending' || st === 'approved' || sovereigntyMode !== 'claim') {
      if (st === 'pending') {
        el.textContent = 'Phase 2 · 主权审核中';
        el.title = '已完成个体启蒙；企业已认领，授权书人工审核中';
      } else if (st === 'approved' || sovereigntyMode === 'sovereign') {
        el.textContent = 'Phase 2 · 工业原厂期';
        el.title = '企业主权已关联，处于工业原厂因子精算阶段';
      } else {
        el.textContent = 'Phase 2 · 企业档案期';
        el.title = '已建立企业空间，可进行因子精算与主权认领';
      }
    } else {
      el.textContent = 'Phase 1 · 个体启蒙期';
      el.title = '尚未完成企业主权关联；此阶段为个人合规启蒙，不含工业原厂战情室权益';
    }
  }

  function hiDoLogout() {
    if (!confirm('确定退出当前账号吗？退出后可重新登录验证认领流程。')) return;
    closeCommerceModal('hi-modal-sovereignty-dossier');
    closeAllHiModals();
    try { sessionStorage.removeItem('hengai_hi_sovereignty_mode'); } catch (e) { /* ignore */ }
    try {
      if (window.parent && window.parent !== window) {
        if (typeof window.parent.doLogout === 'function') {
          window.parent.doLogout();
          return;
        }
        if (window.parent.AppState && typeof window.parent.AppState.updateAuth === 'function') {
          window.parent.AppState.updateAuth(null, null);
        }
        if (typeof window.parent.clearToken === 'function') window.parent.clearToken();
        window.top.location.href = 'index.html';
        return;
      }
    } catch (e) { /* ignore */ }
    if (window.AppState && typeof window.AppState.updateAuth === 'function') {
      window.AppState.updateAuth(null, null);
    }
    if (typeof clearToken === 'function') clearToken();
    window.location.href = 'index.html';
  }

  let activeIndustry = 'steel';
  let pledgeResolver = null;
  let pendingAction = null;
  let pendingConvertCallback = null;
  let recalcQueued = false;
  let gaugeAnimHandle = 0;
  let gaugeDisplayCi = 0;
  const WARROOM_DISPLAY_BASE_CRUSADE = 1420;
  const WARROOM_DISPLAY_BASE_TAX = 128000000;
  const PRESSURE_FALLBACK = 0;
  const TAX_RECOVERY_BASE = 128000000;
  const CRUSADE_DELTA_BASE = 186;
  const TAX_DELTA_BASE = 12800000;
  var resonanceServer = null;
  var lastResonanceProjection = null;
  var sovereigntyMode = 'pending';

  function patchIndustryCommerce(patch) {
    if (!window.AppState || typeof window.AppState.patchState !== 'function') return;
    var ia = Object.assign({}, window.AppState.industryAudit || {}, patch);
    window.AppState.patchState({ industryAudit: ia });
  }

  function isOfficialCertified() {
    var co = window.AppState && window.AppState.company;
    if (co && co.verifiedFactorCertId) return true;
    var ia = window.AppState && window.AppState.industryAudit;
    return !!(ia && ia.hasVerifiedFactor);
  }

  function pressureCount() {
    var m = window.AppState && window.AppState.metrics;
    var n = m && Number(m.crusadeCount);
    if (n > 0) return n;
    return PRESSURE_FALLBACK;
  }

  function captureResonanceServer(force) {
    if (resonanceServer && !force) return;
    var ia = window.AppState && window.AppState.industryAudit;
    if (ia && ia.resonanceServerCrusade != null) {
      resonanceServer = {
        crusadeCount: Number(ia.resonanceServerCrusade) || 0,
        totalTaxPenalty: Number(ia.resonanceServerTax) || 0,
      };
      return;
    }
    var m = window.AppState && window.AppState.metrics;
    if (!m) return;
    resonanceServer = {
      crusadeCount: Number(m.crusadeCount) || 0,
      totalTaxPenalty: Number(m.totalTaxPenalty) || Number(m.total_tax_penalty) || 0,
    };
  }

  function fmtCrusadeKpi(n) {
    n = Number(n) || 0;
    if (window.F && typeof window.F.crusade === 'function') return window.F.crusade(n);
    return n.toLocaleString('zh-CN');
  }

  function fmtTaxKpi(n) {
    n = Number(n) || 0;
    if (n >= 1e6) return '€ ' + n.toLocaleString('en-US');
    if (window.F && typeof window.F.eurYi === 'function') return window.F.eurYi(n);
    if (n >= 1e8) return '€ ' + (n / 1e8).toFixed(2) + '亿';
    return '€ ' + n.toLocaleString('zh-CN');
  }

  function prefersReducedMotion() {
    try { return !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches); }
    catch (_) { return false; }
  }

  function animateNumber(from, to, duration, onTick, onDone) {
    var start = performance.now();
    duration = Math.max(180, duration || 520);
    var rafId = 0;
    var run = function (now) {
      var t = Math.min(1, (now - start) / duration);
      var e = 1 - Math.pow(1 - t, 3);
      var cur = from + (to - from) * e;
      onTick(cur, t);
      if (t < 1) rafId = requestAnimationFrame(run);
      else if (typeof onDone === 'function') onDone();
    };
    rafId = requestAnimationFrame(run);
    return function cancelAnim() {
      if (rafId) cancelAnimationFrame(rafId);
    };
  }

  function paintResonanceKpis(proj) {
    var crusadeEl = document.getElementById('hi-kpi-crusade-display');
    var taxEl = document.getElementById('hi-kpi-tax-display');
    var crusadeTarget = Number(proj.crusadeCount) > 0 ? Number(proj.crusadeCount) : WARROOM_DISPLAY_BASE_CRUSADE;
    var taxTarget = Number(proj.totalTaxPenalty) > 0 ? Number(proj.totalTaxPenalty) : WARROOM_DISPLAY_BASE_TAX;
    var lcdOn = Number(proj.totalTaxPenalty) > 0;
    if (taxEl) taxEl.setAttribute('data-lcd', lcdOn ? 'on' : 'off');

    if (prefersReducedMotion()) {
      if (crusadeEl) crusadeEl.textContent = fmtCrusadeKpi(crusadeTarget);
      if (taxEl) taxEl.textContent = fmtTaxKpi(taxTarget);
      return;
    }

    var fromCru = crusadeEl ? (Number((crusadeEl.textContent || '').replace(/[^\d.-]/g, '')) || 0) : 0;
    var fromTax = taxEl ? (Number((taxEl.textContent || '').replace(/[^\d.-]/g, '')) || 0) : 0;
    animateNumber(fromCru, crusadeTarget, 620, function (v) {
      if (crusadeEl) crusadeEl.textContent = fmtCrusadeKpi(Math.round(v));
    });
    animateNumber(fromTax, taxTarget, 640, function (v) {
      if (taxEl) taxEl.textContent = fmtTaxKpi(Math.round(v));
    });
  }

  function fmtTaxDelta(n) {
    n = Number(n) || 0;
    if (n >= 1e6) return '€' + (n / 1e6).toFixed(1) + 'M';
    if (n >= 1e4) return '€' + Math.round(n / 1e4) + '万';
    return '€' + Math.round(n);
  }

  function projectResonanceMetrics(ci, totalOut) {
    captureResonanceServer();
    var backend = resonanceServer || { crusadeCount: 0, totalTaxPenalty: 0 };
    var meta = INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel;
    var totalSteps = meta.steps.length;
    var filled = countFilledSteps(activeIndustry);
    var completion = totalSteps > 0 ? Math.min(1, filled / totalSteps) : 0;

    if (!ci || ci <= 0 || filled === 0) {
      return {
        crusadeCount: backend.crusadeCount,
        totalTaxPenalty: backend.totalTaxPenalty,
        crusadeDelta: 0,
        taxDelta: 0,
        projected: false,
      };
    }

    var bench = meta.bench;
    if (window.AppState && window.AppState.metrics &&
        window.AppState.metrics.benchmarkCarbonIntensity != null) {
      bench = Number(window.AppState.metrics.benchmarkCarbonIntensity);
    }
    var advRatio = bench > 0 ? Math.max(0, Math.min(1, (bench - ci) / bench)) : 0;

    var crusadeDisplay = backend.crusadeCount;
    if (crusadeDisplay > 0 && getCompanyIndustryKey()) {
      crusadeDisplay = Math.round(crusadeDisplay * industryMetricShare(activeIndustry, 'crusade'));
    }
    if (crusadeDisplay <= 0) {
      var co = window.AppState && window.AppState.company || {};
      var declared = Number(co.declaredSupplierCount) || 0;
      var base = Math.max(PRESSURE_FALLBACK, declared);
      crusadeDisplay = Math.round(base * (0.22 + 0.78 * completion));
    }

    var taxDisplay = backend.totalTaxPenalty;
    if (taxDisplay > 0 && getCompanyIndustryKey()) {
      taxDisplay = Math.round(taxDisplay * industryMetricShare(activeIndustry, 'tax'));
    }
    if (taxDisplay <= 0 && advRatio > 0) {
      taxDisplay = Math.round(TAX_RECOVERY_BASE * completion * advRatio);
      if (totalOut > 0 && completion >= 0.66) {
        var cbamPrice = 75.36;
        if (window.AppState && window.AppState.macro && window.AppState.macro.cbam_current_price) {
          cbamPrice = Number(window.AppState.macro.cbam_current_price);
        }
        var co2 = Math.max(0, bench - ci) * totalOut;
        var localTax = co2 * cbamPrice * (1 + crusadeDisplay / 1200);
        taxDisplay = Math.max(taxDisplay, Math.round(localTax));
      }
    }

    return {
      crusadeCount: crusadeDisplay,
      totalTaxPenalty: taxDisplay,
      crusadeDelta: Math.round(CRUSADE_DELTA_BASE * completion),
      taxDelta: Math.round(TAX_DELTA_BASE * completion * Math.max(advRatio, 0.35)),
      projected: true,
    };
  }

  function updateResonanceDashboard(ci, totalOut) {
    var proj = projectResonanceMetrics(ci, totalOut);
    lastResonanceProjection = proj;
    paintResonanceKpis(proj);

    var deltaCrusade = document.getElementById('hi-delta-crusade-val');
    var deltaTax = document.getElementById('hi-delta-tax-val');
    var deltaCrusadeWrap = document.getElementById('hi-delta-crusade');
    var deltaTaxWrap = document.getElementById('hi-delta-tax');

    if (deltaCrusade) {
      deltaCrusade.textContent = proj.projected && proj.crusadeDelta > 0
        ? String(proj.crusadeDelta) : '—';
    }
    if (deltaTax) {
      deltaTax.textContent = proj.projected && proj.taxDelta > 0
        ? fmtTaxDelta(proj.taxDelta) : '—';
    }
    if (deltaCrusadeWrap) {
      deltaCrusadeWrap.classList.toggle('hi-delta-idle', !proj.projected || proj.crusadeDelta <= 0);
    }
    if (deltaTaxWrap) {
      deltaTaxWrap.classList.toggle('hi-delta-idle', !proj.projected || proj.taxDelta <= 0);
    }

    if (window.AppState) {
      window.AppState.metrics = Object.assign({}, window.AppState.metrics || {}, {
        carbonIntensity: ci > 0 ? ci : (window.AppState.metrics && window.AppState.metrics.carbonIntensity),
        crusadeCount: proj.crusadeCount,
        totalTaxPenalty: proj.totalTaxPenalty,
      });
      if (typeof window.AppState.patchState === 'function') {
        window.AppState.patchState({
          industryAudit: Object.assign({}, window.AppState.industryAudit || {}, {
            resonanceProjected: proj.projected,
            resonanceCompletion: countFilledSteps(activeIndustry),
          }),
          metrics: window.AppState.metrics,
        }, { emitStateSynced: false });
      }
    }
    renderAuditLog(ci);
  }

  function sovereigntyClaimStatus() {
    var co = window.AppState && window.AppState.company || {};
    var st = String(co.sovereigntyClaimStatus || co.sovereignty_claim_status || '').toLowerCase();
    if (st && st !== 'none') return st;
    try {
      var cached = sessionStorage.getItem('hengai_hi_sovereignty_mode');
      if (cached === 'pending' || cached === 'approved') return cached;
    } catch (e) { /* ignore */ }
    return 'none';
  }

  function patchCompanySovereignty(patch) {
    if (!window.AppState) window.AppState = {};
    window.AppState.company = Object.assign({}, window.AppState.company || {}, patch || {});
    var st = patch && (patch.sovereigntyClaimStatus || patch.sovereignty_claim_status);
    if (st && st !== 'none') {
      try { sessionStorage.setItem('hengai_hi_sovereignty_mode', st); } catch (e) { /* ignore */ }
    }
    if (st === 'rejected' || st === 'none') {
      try { sessionStorage.removeItem('hengai_hi_sovereignty_mode'); } catch (e) { /* ignore */ }
    }
  }

  function closeAllHiModals() {
    document.querySelectorAll('#hi-suite .hi-commerce-modal').forEach(function (el) {
      el.hidden = true;
      el.classList.remove('show');
    });
  }

  function forceShowWarRoom() {
    var gate = document.getElementById('hi-claim-gate');
    var main = document.getElementById('hi-warroom-main');
    closeAllHiModals();
    if (gate) {
      gate.hidden = true;
      gate.style.display = 'none';
    }
    if (main) {
      main.hidden = false;
      main.removeAttribute('hidden');
      main.style.display = '';
    }
    sovereigntyMode = 'pending';
    var suite = document.getElementById('hi-suite');
    if (suite) {
      suite.classList.remove('hi-mode-claim');
      suite.classList.add('hi-mode-pending');
      suite.classList.remove('hi-mode-sovereign');
    }
    var pendingBanner = document.getElementById('hi-pending-banner');
    if (pendingBanner) pendingBanner.hidden = false;
    var lamp = document.getElementById('hi-sovereignty-lamp');
    if (lamp) {
      lamp.textContent = '🟡 授权书审核中';
      lamp.className = 'hi-sovereignty-lamp hi-lamp-amber';
    }
    try {
      if (window.parent && window.parent !== window) {
        window.parent.postMessage({ type: 'HENGAI_DATA_CHANGED', source: 'sovereignty-claim' }, '*');
      }
    } catch (e) { /* ignore */ }
    try { main && main.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e2) { /* ignore */ }
  }

  function companyIsComplete() {
    var co = window.AppState && window.AppState.company || {};
    var st = sovereigntyClaimStatus();
    if (st === 'approved') return true;
    if (co.is_complete === true || co.isComplete === true) {
      var credit = String(co.creditCode || co.credit_code || '').trim();
      var name = String(co.name || '').trim();
      if (name && credit && credit.indexOf('TEMP-') !== 0 && st !== 'none' && st !== 'rejected') return true;
    }
    var credit = String(co.creditCode || co.credit_code || '').trim();
    var name = String(co.name || '').trim();
    return !!(name && credit && credit.indexOf('TEMP-') !== 0 && st === 'approved');
  }

  function resolveSovereigntyMode() {
    var st = sovereigntyClaimStatus();
    if (st === 'none' || st === 'rejected') return 'claim';
    if (st === 'pending') return 'pending';
    if (st === 'approved' || isOfficialCertified()) return 'sovereign';
    return 'pending';
  }

  function sovereigntyStatusLabel(st) {
    if (st === 'pending') return '🟡 待人工审核';
    if (st === 'approved') return '🟢 主权已确权';
    if (st === 'rejected') return '🔴 审核驳回';
    return '🔴 待主权认领';
  }

  function applySovereigntyGate() {
    sovereigntyMode = resolveSovereigntyMode();
    var suite = document.getElementById('hi-suite');
    var gate = document.getElementById('hi-claim-gate');
    var main = document.getElementById('hi-warroom-main');
    var lamp = document.getElementById('hi-sovereignty-lamp');
    var mark = document.getElementById('hi-enterprise-mark');
    var co = window.AppState && window.AppState.company || {};
    var st = sovereigntyClaimStatus();

    if (gate) gate.hidden = sovereigntyMode !== 'claim';
    if (main) main.hidden = sovereigntyMode === 'claim';
    var pendingBanner = document.getElementById('hi-pending-banner');
    if (pendingBanner) pendingBanner.hidden = sovereigntyMode !== 'pending';
    if (suite) {
      suite.classList.toggle('hi-mode-claim', sovereigntyMode === 'claim');
      suite.classList.toggle('hi-mode-pending', sovereigntyMode === 'pending');
      suite.classList.toggle('hi-mode-sovereign', sovereigntyMode === 'sovereign');
    }
    if (lamp) {
      if (sovereigntyMode === 'claim') {
        lamp.textContent = st === 'rejected' ? '🔴 审核驳回 · 请重提' : '🔴 待主权认领';
        lamp.className = 'hi-sovereignty-lamp hi-lamp-red';
      } else if (sovereigntyMode === 'pending') {
        lamp.textContent = '🟡 授权书审核中';
        lamp.className = 'hi-sovereignty-lamp hi-lamp-amber';
      } else {
        lamp.textContent = '🟢 全功能主权模式';
        lamp.className = 'hi-sovereignty-lamp hi-lamp-green';
      }
    }
    if (mark) {
      mark.title = '点击查看主权认领档案 · ' + sovereigntyStatusLabel(st);
    }
    var nameInp = document.getElementById('hi-claim-name');
    if (nameInp && co.name && !nameInp.value) nameInp.value = co.name;
    var creditInp = document.getElementById('hi-claim-credit');
    if (creditInp && (co.creditCode || co.credit_code) && !creditInp.value) {
      creditInp.value = co.creditCode || co.credit_code;
    }
    if (st === 'rejected' && gate) {
      var rejNote = co.sovereigntyClaimReviewerNote || co.sovereignty_claim_reviewer_note;
      var desc = gate.querySelector('.hi-claim-desc');
      if (desc && rejNote) {
        desc.innerHTML = '上次认领被驳回：<strong>' + rejNote + '</strong>。请重新上传符合要求的盖章授权书。';
      }
    }
    if (st === 'pending' || st === 'approved') {
      try { sessionStorage.setItem('hengai_hi_sovereignty_mode', st); } catch (e) { /* ignore */ }
    }
    refreshWarroomPhaseTag();
    applyIndustryScope();
  }

  var pendingClaimPayload = null;

  function openClaimConfirmModal() {
    var credit = (document.getElementById('hi-claim-credit').value || '').trim();
    var name = (document.getElementById('hi-claim-name').value || '').trim();
    var fileInp = document.getElementById('hi-claim-auth');
    if (!credit || credit.length < 15) {
      if (typeof showToast === 'function') showToast('请输入有效的 18 位统一社会信用代码');
      return;
    }
    if (!name) {
      if (typeof showToast === 'function') showToast('请填写企业全称');
      return;
    }
    if (!fileInp || !fileInp.files || !fileInp.files.length) {
      if (typeof showToast === 'function') showToast('请上传主权授权书');
      return;
    }
    var file = fileInp.files[0];
    pendingClaimPayload = { credit: credit, name: name, file: file };
    document.getElementById('hi-confirm-name').textContent = name;
    document.getElementById('hi-confirm-credit').textContent = credit;
    document.getElementById('hi-confirm-file').textContent = file.name + ' (' + Math.max(1, Math.round(file.size / 1024)) + ' KB)';
    var agree = document.getElementById('hi-confirm-agree');
    var submitBtn = document.getElementById('hi-modal-confirm-submit');
    if (agree) { agree.checked = false; }
    if (submitBtn) submitBtn.disabled = true;
    var previewWrap = document.getElementById('hi-confirm-preview-wrap');
    var previewImg = document.getElementById('hi-confirm-preview-img');
    if (previewWrap && previewImg && file.type && file.type.indexOf('image/') === 0) {
      previewImg.src = URL.createObjectURL(file);
      previewWrap.hidden = false;
    } else if (previewWrap) {
      previewWrap.hidden = true;
    }
    openCommerceModal('hi-modal-claim-confirm');
  }

  function mergeHubAppState(remote) {
    if (!remote || typeof remote !== 'object') return;
    if (!window.AppState) window.AppState = {};
    if (typeof window.deepMerge === 'function') {
      Object.assign(window.AppState, window.deepMerge(window.AppState, remote));
    } else {
      Object.assign(window.AppState, remote);
      if (remote.company) {
        window.AppState.company = Object.assign({}, window.AppState.company || {}, remote.company);
      }
    }
    try {
      if (typeof saveCachedState === 'function') saveCachedState(window.AppState);
    } catch (e) { /* ignore */ }
    if (typeof syncAppState === 'function') syncAppState(undefined, { fromRemote: true, emitStateSynced: false });
  }

  function enterWarRoomAfterClaim(message) {
    resonanceServer = null;
    applySovereigntyGate();
    forceShowWarRoom();
    bindAppState();
    bindEnterpriseLogo();
    if (typeof showToast === 'function') showToast(message || '已进入战情室 · 授权书人工审核中');
  }

  async function executeSovereigntyClaimSubmit() {
    if (!pendingClaimPayload) return;
    var submitBtn = document.getElementById('hi-modal-confirm-submit');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = '上传存证中…'; }
    var payloadSnapshot = pendingClaimPayload;
    try {
      var fd = new FormData();
      fd.append('name', payloadSnapshot.name);
      fd.append('credit_code', payloadSnapshot.credit);
      fd.append('industry_code', resolveWorkspaceIndustryKey());
      fd.append('file', payloadSnapshot.file);
      var t = typeof getToken === 'function' ? getToken() : (localStorage.getItem('hengai_token') || localStorage.getItem('authToken') || '');
      var headers = t ? { Authorization: 'Bearer ' + t, Accept: 'application/json' } : { Accept: 'application/json' };
      var res = await fetch(apiBase() + '/api/v1/hub/sovereignty-claim-submit', {
        method: 'POST',
        credentials: 'include',
        headers: headers,
        body: fd,
      });
      var data = await res.json().catch(function () { return {}; });
      var detail = data.detail;
      if (Array.isArray(detail)) detail = detail.map(function (x) { return x.msg || String(x); }).join('；');
      var detailStr = typeof detail === 'string' ? detail : '';

      if (!res.ok) {
        if (res.status === 409 && /审核中/.test(detailStr)) {
          patchCompanySovereignty({
            name: payloadSnapshot.name,
            creditCode: payloadSnapshot.credit,
            isComplete: true,
            is_complete: true,
            sovereigntyClaimStatus: 'pending',
            sovereignty_claim_status: 'pending',
          });
          pendingClaimPayload = null;
          enterWarRoomAfterClaim('认领申请已在审核中 · 已进入战情室');
          return;
        }
        throw new Error(detailStr || data.message || res.statusText);
      }

      patchCompanySovereignty({
        name: payloadSnapshot.name,
        creditCode: payloadSnapshot.credit,
        isComplete: true,
        is_complete: true,
        sovereigntyClaimStatus: 'pending',
        sovereignty_claim_status: 'pending',
        sovereigntyClaimSubmittedAt: new Date().toISOString(),
      });
      var remote = data.appState || data.app_state;
      if (remote) mergeHubAppState(remote);
      else if (data.sovereigntyClaimStatus || data.sovereignty_claim_status) {
        patchCompanySovereignty({
          sovereigntyClaimStatus: data.sovereigntyClaimStatus || data.sovereignty_claim_status,
        });
      }
      pendingClaimPayload = null;
      enterWarRoomAfterClaim(data.message || '主权认领已提交 · 已进入战情室（待人工审核）');
    } catch (e) {
      var msg = (e && e.message) || '提交失败';
      if (typeof showToast === 'function') showToast(msg, 'err');
      else alert(msg);
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '确认提交 · 上传存证'; }
    }
  }

  function renderSovereigntyDossier() {
    var co = window.AppState && window.AppState.company || {};
    var st = sovereigntyClaimStatus();
    var badge = document.getElementById('hi-dossier-status-badge');
    if (badge) {
      badge.textContent = sovereigntyStatusLabel(st);
      badge.className = 'hi-dossier-status hi-dossier-' + st;
    }
    var set = function (id, val) { var el = document.getElementById(id); if (el) el.textContent = val || '—'; };
    set('hi-dossier-name', co.name);
    set('hi-dossier-credit', co.creditCode || co.credit_code);
    set('hi-dossier-submitted', co.sovereigntyClaimSubmittedAt || co.sovereignty_claim_submitted_at || '—');
    set('hi-dossier-reviewed', co.sovereigntyClaimReviewedAt || co.sovereignty_claim_reviewed_at || '—');
    set('hi-dossier-file', co.sovereigntyAuthLetterFilename || co.sovereignty_auth_letter_filename || '—');
    var noteRow = document.getElementById('hi-dossier-note-row');
    var note = co.sovereigntyClaimReviewerNote || co.sovereignty_claim_reviewer_note;
    if (noteRow) noteRow.hidden = !note;
    set('hi-dossier-note', note);
    var aiRow = document.getElementById('hi-dossier-ai-row');
    var ai = co.sovereigntyAiPrescreen || co.sovereignty_ai_prescreen;
    if (aiRow && ai) {
      aiRow.hidden = false;
      var parts = [];
      if (ai.nameMatch === false) parts.push('⚠️ 企业名称与表单不一致');
      else if (ai.nameMatch === true) parts.push('✓ 企业名称初步匹配');
      if (ai.creditMatch === false) parts.push('⚠️ 信用代码与表单不一致');
      else if (ai.creditMatch === true) parts.push('✓ 信用代码初步匹配');
      if (ai.hasSeal === false) parts.push('⚠️ 未见清晰公章');
      else if (ai.hasSeal === true) parts.push('✓ 可见签章要素');
      if (ai.isLikelyAuthLetter === false) parts.push('⚠️ 可能不是授权书');
      var aiTxt = parts.length ? parts.join(' · ') : (ai.note || '—');
      aiTxt += ' · 最终以人工审核为准';
      set('hi-dossier-ai', aiTxt);
    } else if (aiRow) aiRow.hidden = true;
    var viewDoc = document.getElementById('hi-dossier-view-doc');
    if (viewDoc) viewDoc.hidden = !(st === 'pending' || st === 'approved' || st === 'rejected');
  }

  function claimFormValues() {
    var co = window.AppState && window.AppState.company || {};
    return {
      name: (document.getElementById('hi-claim-name') && document.getElementById('hi-claim-name').value.trim()) || co.name || '',
      credit: (document.getElementById('hi-claim-credit') && document.getElementById('hi-claim-credit').value.trim()) || co.creditCode || co.credit_code || '',
    };
  }

  function triggerBlobDownload(blob, filename) {
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.rel = 'noopener';
    a.style.display = 'none';
    document.body.appendChild(a);
    a.click();
    setTimeout(function () {
      URL.revokeObjectURL(url);
      if (a.parentNode) a.parentNode.removeChild(a);
    }, 800);
  }

  async function downloadSovereigntyTemplate(format) {
    format = format || 'doc';
    var v = claimFormValues();
    var qs = '?format=' + encodeURIComponent(format === 'pdf' ? 'html' : format);
    if (v.name) qs += '&name=' + encodeURIComponent(v.name);
    if (v.credit) qs += '&credit_code=' + encodeURIComponent(v.credit);

    if (format === 'pdf') {
      await downloadSovereigntyTemplatePdf(v.name, v.credit);
      return;
    }

    try {
      var t = typeof getToken === 'function' ? getToken() : (localStorage.getItem('hengai_token') || localStorage.getItem('authToken') || '');
      var headers = { Accept: '*/*' };
      if (t) headers.Authorization = 'Bearer ' + t;
      var res = await fetch(apiBase() + '/api/v1/hub/sovereignty-claim/template' + qs, { credentials: 'include', headers: headers });
      if (!res.ok) throw new Error('下载失败（HTTP ' + res.status + '）');
      var blob = await res.blob();
      if (!blob || !blob.size) throw new Error('服务器返回空文件');
      triggerBlobDownload(blob, format === 'doc' ? 'CL-COP-sovereignty-auth-letter.doc' : 'CL-COP-sovereignty-auth-letter.html');
      if (typeof showToast === 'function') showToast('Word 范本已保存 · 请法务审定后打印盖章，再扫描上传', 'warn');
    } catch (e) {
      if (typeof showToast === 'function') showToast((e && e.message) || '下载失败，请确认后端已启动', 'err');
    }
  }

  var SOVEREIGNTY_PDF_CSS = [
    '.hi-tpl-pdf{font-family:SimSun,宋体,STSong,serif;font-size:12pt;line-height:1.75;color:#111;margin:0;padding:0}',
    '.hi-tpl-pdf h1{text-align:center;font-size:18pt;letter-spacing:4px;margin:0 0 6px;font-weight:700}',
    '.hi-tpl-pdf .subtitle{text-align:center;font-size:10pt;color:#444;margin:0 0 16px}',
    '.hi-tpl-pdf .meta{text-align:right;font-size:10pt;color:#444;margin:0 0 14px}',
    '.hi-tpl-pdf .section{margin:14px 0 6px;font-weight:700;font-size:12pt}',
    '.hi-tpl-pdf .block{margin:6px 0;text-indent:2em}',
    '.hi-tpl-pdf .clause{margin:4px 0 4px 2em;text-indent:0}',
    '.hi-tpl-pdf .field{border-bottom:1px solid #333;padding:0 4px 1px}',
    '.hi-tpl-pdf .sign{margin-top:24px;line-height:2.2}',
    '.hi-tpl-pdf .sign-line{border-bottom:1px solid #333;display:inline-block;min-width:180px}',
    '.hi-tpl-pdf .footer{margin-top:20px;padding:10px 12px;border:1px dashed #666;font-size:9pt;color:#444;line-height:1.6;background:#fafafa}',
    '.hi-tpl-pdf table{width:100%;border-collapse:collapse;margin:10px 0;font-size:10pt}',
    '.hi-tpl-pdf th,.hi-tpl-pdf td{border:1px solid #333;padding:6px 8px;text-align:left;vertical-align:top}',
    '.hi-tpl-pdf th{background:#f0f0f0;width:28%}',
    '.hi-tpl-pdf table,.hi-tpl-pdf .sign,.hi-tpl-pdf .footer{page-break-inside:avoid}'
  ].join('');

  async function sovereigntyTemplateHtmlForPdf(name, credit) {
    var t = typeof getToken === 'function' ? getToken() : (localStorage.getItem('hengai_token') || localStorage.getItem('authToken') || '');
    var headers = { Accept: 'text/html,*/*' };
    if (t) headers.Authorization = 'Bearer ' + t;
    var qs = '?format=html';
    if (name) qs += '&name=' + encodeURIComponent(name);
    if (credit) qs += '&credit_code=' + encodeURIComponent(credit);
    var res = await fetch(apiBase() + '/api/v1/hub/sovereignty-claim/template' + qs, { credentials: 'include', headers: headers });
    if (!res.ok) throw new Error('获取范本失败（HTTP ' + res.status + '）');
    var htmlText = await res.text();
    var parser = new DOMParser();
    var doc = parser.parseFromString(htmlText, 'text/html');
    var bodyHtml = doc.body ? doc.body.innerHTML : htmlText;
    if (!bodyHtml || !bodyHtml.trim()) throw new Error('范本内容为空，请确认后端已更新并重启');
    return '<style>' + SOVEREIGNTY_PDF_CSS + '</style><div class="hi-tpl-pdf">' + bodyHtml + '</div>';
  }

  async function downloadSovereigntyTemplatePdf(name, credit) {
    if (typeof html2pdf === 'undefined') {
      if (typeof showToast === 'function') showToast('PDF 组件未加载，请使用 Word 范本', 'err');
      return;
    }
    try {
      if (typeof showToast === 'function') showToast('正在生成 PDF 范本…', 'warn');
      var pdfHtml = await sovereigntyTemplateHtmlForPdf(name, credit);
      var ok = await renderPdfToFile(pdfHtml, 'CL-COP-sovereignty-auth-letter.pdf');
      if (!ok) throw new Error('PDF 渲染失败');
      if (typeof showToast === 'function') showToast('PDF 范本已保存 · 请打印后签字盖章再扫描上传', 'ok');
    } catch (e) {
      if (typeof showToast === 'function') showToast((e && e.message) || 'PDF 生成失败，可先下载 Word 范本', 'err');
    }
  }

  function previewSovereigntyTemplate() {
    var v = claimFormValues();
    var qs = '?format=html';
    if (v.name) qs += '&name=' + encodeURIComponent(v.name);
    if (v.credit) qs += '&credit_code=' + encodeURIComponent(v.credit);
    window.open(apiBase() + '/api/v1/hub/sovereignty-claim/template' + qs, '_blank', 'noopener');
  }

  async function submitSovereigntyClaim(ev) {
    if (ev && ev.preventDefault) ev.preventDefault();
    openClaimConfirmModal();
  }

  function renderAuditLog(ci) {
    var list = document.getElementById('hi-audit-list');
    if (!list) return;
    var entries = [];
    var certified = isOfficialCertified();
    var filled = countFilledSteps(activeIndustry);
    var meta = INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel;

    var st = sovereigntyClaimStatus();
    var co = window.AppState && window.AppState.company || {};
    if (st === 'pending') {
      entries.unshift({
        ts: co.sovereigntyClaimSubmittedAt ? String(co.sovereigntyClaimSubmittedAt).slice(0, 16).replace('T', ' ') : '—',
        text: '主权授权书已提交 · 等待 HEGC 人工审核',
        cls: 'wait',
      });
    } else if (st === 'approved') {
      entries.unshift({
        ts: co.sovereigntyClaimReviewedAt ? String(co.sovereigntyClaimReviewedAt).slice(0, 16).replace('T', ' ') : '—',
        text: '主权认领人工审核通过 · 企业标识已激活',
        cls: 'ok',
      });
    } else if (st === 'rejected') {
      entries.unshift({
        ts: co.sovereigntyClaimReviewedAt ? String(co.sovereigntyClaimReviewedAt).slice(0, 16).replace('T', ' ') : '—',
        text: '主权认领被驳回 · ' + (co.sovereigntyClaimReviewerNote || '请重新上传授权书'),
        cls: 'idle',
      });
    }

    entries.push({
      ts: '2026-05-04 14:00',
      text: 'AI Agent 物理逻辑预审通过',
      cls: ci > 0 && filled >= meta.steps.length ? 'ok' : 'idle',
    });
    if (certified) {
      entries.push({
        ts: new Date().toISOString().slice(0, 16).replace('T', ' '),
        text: 'HEGC 专家组人工核验通过 · 官方因子已确权',
        cls: 'ok',
      });
    } else if (ci > 0 && filled > 0) {
      entries.push({
        ts: '2026-05-04 16:30',
        text: '正在等待 HEGC 专家组人工核验...',
        cls: 'wait',
      });
    } else {
      entries.push({
        ts: '—',
        text: '完成工序录入后将启动 AI 物理逻辑预审',
        cls: 'idle',
      });
    }

    list.innerHTML = entries.map(function (e) {
      return '<li class="hi-audit-item hi-audit-' + e.cls + '"><span class="hi-audit-ts">' + e.ts + '</span><span class="hi-audit-txt">' + e.text + '</span></li>';
    }).join('');
    var chip = document.getElementById('hi-audit-chip');
    if (chip) {
      var waitCnt = entries.filter(function (e) { return e.cls === 'wait'; }).length;
      var okCnt = entries.filter(function (e) { return e.cls === 'ok'; }).length;
      if (okCnt > 0 && waitCnt === 0) {
        chip.textContent = '已完成 ' + okCnt + ' 项';
        chip.className = 'hi-audit-chip ok';
      } else if (waitCnt > 0) {
        chip.textContent = '待处理 ' + waitCnt + ' 项';
        chip.className = 'hi-audit-chip wait';
      } else {
        chip.textContent = '待启动';
        chip.className = 'hi-audit-chip';
      }
    }
  }

  function attestCoverageCount() {
    return Math.max(0, pressureCount());
  }

  function refreshResonanceHeader() {
    var el = document.getElementById('hi-resonance-req-count');
    if (!el) return;
    var n = pressureCount();
    var res = window.AppState && window.AppState.resonance;
    if (res && Number(res.pendingRequestsForIndustry) > 0) {
      n = Math.max(n, Number(res.pendingRequestsForIndustry));
    }
    el.textContent = String(n);
  }

  function showGoldenSealCeremony(certId, verificationCode) {
    var modal = document.getElementById('hi-golden-seal-modal');
    var idEl = document.getElementById('hi-golden-seal-id');
    var vcEl = document.getElementById('hi-golden-seal-vcode');
    if (idEl) idEl.textContent = certId || '—';
    if (vcEl) vcEl.textContent = verificationCode || '—';
    if (modal) {
      modal.hidden = false;
      modal.classList.add('show');
    }
  }

  function closeGoldenSealCeremony() {
    var modal = document.getElementById('hi-golden-seal-modal');
    if (modal) {
      modal.hidden = true;
      modal.classList.remove('show');
    }
  }

  function attestComputeUnits(coverage) {
    coverage = coverage || attestCoverageCount();
    return Math.max(80, Math.min(320, Math.round(coverage * 0.282)));
  }

  function playPressSound() {
    try {
      var Ctx = window.AudioContext || window.webkitAudioContext;
      if (!Ctx) return;
      var ctx = new Ctx();
      var t0 = ctx.currentTime;
      function thud(at, freq, dur, vol) {
        var o = ctx.createOscillator();
        var g = ctx.createGain();
        o.type = 'sine';
        o.frequency.setValueAtTime(freq, at);
        o.frequency.exponentialRampToValueAtTime(freq * 0.4, at + dur);
        g.gain.setValueAtTime(0.0001, at);
        g.gain.exponentialRampToValueAtTime(vol, at + 0.012);
        g.gain.exponentialRampToValueAtTime(0.0001, at + dur);
        o.connect(g);
        g.connect(ctx.destination);
        o.start(at);
        o.stop(at + dur + 0.02);
      }
      thud(t0, 180, 0.22, 0.55);
      thud(t0 + 0.09, 95, 0.35, 0.7);
      thud(t0 + 0.2, 60, 0.4, 0.45);
      setTimeout(function () { ctx.close(); }, 900);
    } catch (e) { /* optional audio */ }
  }

  function triggerPressAnimation(done) {
    var fx = document.getElementById('hi-press-fx');
    var stamp = document.getElementById('hi-press-stamp');
    if (!fx || !stamp) {
      if (typeof done === 'function') done();
      return;
    }
    playPressSound();
    fx.hidden = false;
    stamp.classList.remove('hi-press-hit');
    void stamp.offsetWidth;
    stamp.classList.add('hi-press-hit');
    var finished = false;
    function finish() {
      if (finished) return;
      finished = true;
      fx.hidden = true;
      stamp.classList.remove('hi-press-hit');
      if (typeof done === 'function') done();
    }
    stamp.addEventListener('animationend', finish, { once: true });
    setTimeout(finish, 1200);
  }

  function estimateServiceFee(units) {
    var amt = Math.round(units * 2800);
    return '￥' + amt.toLocaleString('zh-CN') + ' 起（示意，以合同为准）';
  }

  function updateEmpowermentMeta() {
    var cov = attestCoverageCount();
    var units = attestComputeUnits(cov);
    var fee = estimateServiceFee(units);
    var covInline = document.getElementById('hi-attest-coverage-inline');
    var covConvert = document.getElementById('hi-convert-coverage');
    var feeEl = document.getElementById('hi-convert-fee');
    if (covInline) covInline.textContent = String(cov);
    if (covConvert) covConvert.textContent = String(cov);
    if (feeEl) feeEl.textContent = fee;
    var serial = document.getElementById('hi-note-serial');
    if (serial) {
      var cert = window.AppState && window.AppState.company && window.AppState.company.verifiedFactorCertId;
      serial.textContent = 'NO. ' + (cert ? String(cert).slice(-8).toUpperCase() : 'DRAFT');
    }
  }

  function updateDraftStatus(ci) {
    var el = document.getElementById('hi-draft-status');
    if (!el) return;
    if (isOfficialCertified()) {
      el.innerHTML = '<span class="hi-draft-badge hi-draft-certified">✓ CL-IVC 官方校准因子</span>' +
        '<p class="hi-draft-note">ℹ️ 该强度指标已存入核验池，具备产业链共享与合规申报效力。</p>';
    } else if (ci > 0) {
      el.innerHTML = '<span class="hi-draft-badge">📝 原始数据草案 / 内部参考</span>' +
        '<p class="hi-draft-note">ℹ️ 该结果尚未经过 CL-IVC 官方算法校准，暂不具备出口确权与政策申报效力。</p>';
    } else {
      el.innerHTML = '<span class="hi-draft-badge hi-draft-idle">待录入工序数据</span>' +
        '<p class="hi-draft-note">ℹ️ 完成工序矩阵本地精算后，可生成内部参考草案与预算申请包。</p>';
    }
  }

  function showPolicyCard(ci) {
    var card = document.getElementById('hi-policy-card');
    if (!card) return;
    if (ci > 0 && !isOfficialCertified()) {
      card.hidden = false;
      requestAnimationFrame(function () { card.classList.add('hi-policy-show'); });
    } else {
      card.classList.remove('hi-policy-show');
      if (isOfficialCertified() || !(ci > 0)) card.hidden = true;
    }
  }

  function scrollToPolicyCard() {
    var card = document.getElementById('hi-policy-card');
    if (card) {
      card.hidden = false;
      card.classList.add('hi-policy-show');
      card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  function benchAdvantage(ci) {
    if (!ci || ci <= 0) return null;
    var meta = INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel;
    var bench = meta.bench;
    if (window.AppState && window.AppState.metrics &&
        window.AppState.metrics.benchmarkCarbonIntensity != null) {
      bench = Number(window.AppState.metrics.benchmarkCarbonIntensity);
    }
    if (!bench) return null;
    return bench - ci;
  }

  function applyEmpowermentUI() {
    updateEmpowermentMeta();
    var ci = parseFloat(document.getElementById('hi-curr-ci').value) || 0;
    if (!ci && window.AppState && window.AppState.industryAudit) {
      ci = Number(window.AppState.industryAudit.localCarbonIntensity) || 0;
    }
    updateDraftStatus(ci);
    showPolicyCard(ci);
    renderInfluenceRank(activeIndustry, false);
    renderExecutionBrief(ci);
  }

  function renderExecutionBrief(ciValue) {
    var ci = Number(ciValue);
    if (!(ci > 0)) {
      ci = parseFloat(document.getElementById('hi-curr-ci').value) || 0;
    }
    var meta = INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel;
    var totalSteps = (meta && meta.steps && meta.steps.length) ? meta.steps.length : 0;
    var filled = countFilledSteps(activeIndustry);
    var coverage = attestCoverageCount();
    var certified = isOfficialCertified();
    var progressPct = totalSteps > 0 ? Math.min(100, Math.round((filled / totalSteps) * 100)) : 0;
    var ciDecimals = meta.calcMode === 'rtk' ? 6 : (meta.calcMode === 'idc' ? 3 : 3);

    var setTxt = function (id, txt) {
      var el = document.getElementById(id);
      if (el) el.textContent = txt;
    };
    setTxt('hi-brief-filled-steps', String(filled));
    setTxt('hi-brief-total-steps', String(totalSteps));
    setTxt('hi-brief-coverage', String(coverage));
    setTxt('hi-brief-ci', ci > 0 ? (ci.toFixed(ciDecimals) + ' ' + (meta.unitRing || 'tCO₂e/t')) : '—');
    setTxt('hi-brief-cert-status', certified ? '官方认证态（可用于核验签发）' : '草案态（待官方确权）');
    var certEl = document.getElementById('hi-brief-cert-status');
    if (certEl) certEl.style.color = certified ? 'var(--green-l)' : 'var(--gold-l)';

    var nextAction = '先完成至少 1 个工序录入';
    var actionTone = 'warn';
    var briefState = 'state-draft';
    if (filled > 0 && !certified) {
      nextAction = '提交主权认领并等待人工审核';
      actionTone = 'warn';
      briefState = 'state-ready';
    } else if (certified && coverage > 0) {
      nextAction = '前往核验中心完成批次签发';
      actionTone = 'ok';
      briefState = 'state-certified';
    } else if (certified && coverage <= 0) {
      nextAction = '前往供应链协同补全上游来源';
      actionTone = '';
      briefState = 'state-ready';
    }
    var actionEl = document.getElementById('hi-brief-next-action');
    if (actionEl) {
      actionEl.textContent = nextAction;
      actionEl.className = 'hi-eb-action' + (actionTone ? (' ' + actionTone) : '');
    }
    var briefEl = document.getElementById('hi-exec-brief');
    if (briefEl) briefEl.className = 'hi-glass hi-eb ' + briefState;

    var p = document.getElementById('hi-brief-progress');
    if (p) p.style.width = progressPct + '%';
  }

  function openCommerceModal(id) {
    var el = document.getElementById(id);
    if (el) { el.hidden = false; el.classList.add('show'); }
  }
  function closeCommerceModal(id) {
    var el = document.getElementById(id);
    if (el) { el.hidden = true; el.classList.remove('show'); }
  }

  function closeSovereigntyDossier() {
    closeCommerceModal('hi-modal-sovereignty-dossier');
  }

  function wireCommerceModalDismiss() {
    document.querySelectorAll('#hi-suite .hi-commerce-modal').forEach(function (modal) {
      modal.addEventListener('click', function (e) {
        if (e.target === modal) closeCommerceModal(modal.id);
      });
    });
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      var open = document.querySelector('#hi-suite .hi-commerce-modal.show:not([hidden])');
      if (open) closeCommerceModal(open.id);
    });
  }

  function requireOfficialChannel(cb) {
    if (isOfficialCertified()) {
      cb();
      return;
    }
    updateEmpowermentMeta();
    pendingConvertCallback = cb;
    openCommerceModal('hi-modal-convert');
  }

  function hiAssetUrl(rel) {
    try {
      return new URL(rel, document.baseURI || window.location.href).href;
    } catch (e) {
      return rel;
    }
  }

  function wireClOriginLogos() {
    var url = hiAssetUrl('assets/logo.png');
    document.querySelectorAll('.hi-logo-clone').forEach(function (img) {
      img.src = url;
      img.onerror = function () { this.classList.add('hi-logo-missing'); };
      img.onload = function () { this.classList.remove('hi-logo-missing'); };
    });
  }

  function bindEnterpriseLogo() {
    var img = document.getElementById('hi-enterprise-logo');
    var fb = document.getElementById('hi-enterprise-logo-fb');
    var co = window.AppState && window.AppState.company;
    var url = co && (co.logoUrl || co.logo_url || co.avatarUrl || co.avatar_url);
    var name = (co && co.name) ? String(co.name).trim() : '';
    if (fb) fb.textContent = name ? name.slice(0, 2) : '企';
    if (img && url) {
      img.src = url;
      img.hidden = false;
      if (fb) fb.style.display = 'none';
    } else {
      if (img) { img.removeAttribute('src'); img.hidden = true; }
      if (fb) fb.style.display = '';
    }
  }
  wireClOriginLogos();

  function apiBase() {
    if (typeof hengaiApiOrigin === 'function') return hengaiApiOrigin();
    if (window.APP_CONFIG && window.APP_CONFIG.apiBase) return String(window.APP_CONFIG.apiBase).replace(/\/$/, '');
    return '';
  }

  function authHeaders() {
    const t = typeof getToken === 'function' ? getToken() : (localStorage.getItem('hengai_token') || localStorage.getItem('authToken') || '');
    return t ? { Authorization: 'Bearer ' + t, Accept: 'application/json', 'Content-Type': 'application/json' } : { Accept: 'application/json', 'Content-Type': 'application/json' };
  }

  function mountFlow(flowId, steps) {
    const el = document.getElementById(flowId);
    if (!el) return;
    const parts = [];
    steps.forEach(function (s, i) {
      if (i) parts.push('<div class="hi-p-arrow" aria-hidden="true">→</div>');
      parts.push('<div class="hi-p-node" title="' + s[0] + '"><span class="hi-p-ico">' + s[3] + '</span><span class="hi-p-name">' + s[0] + '</span></div>');
    });
    el.innerHTML = parts.join('');
  }

  function mountMatrix(key, meta) {
    const steps = meta.steps;
    const head = document.getElementById(meta.head);
    const body = document.getElementById(meta.body);
    if (!head || !body) return;
    head.innerHTML = '<th class="hi-m-corner">参数类别</th>' + steps.map(function (s, i) {
      return '<th class="hi-m-col-h">' + (i + 1) + '·' + s[0] + '</th>';
    }).join('');

    const rowDefs = getMatrixRowDefs(meta);

    var bodyHtml = rowDefs.map(function (rd) {
      const cells = steps.map(function (s, i) {
        if (!rd.inp) {
          return '<td class="hi-m-emit-val" data-key="' + key + '" data-step="' + i + '" data-field="emit">—</td>';
        }
        const val = rd.defIdx != null ? ' value="' + s[rd.defIdx] + '"' : '';
        var bulb = (rd.defIdx != null && rd.field !== 'output')
          ? '<button type="button" class="hi-m-bulb" data-bench="' + s[rd.defIdx] + '" data-lbl="' + rd.label + '" title="行业对标参考">💡</button>'
          : '';
        return '<td><div class="hi-m-inp-wrap"><input class="hi-inp-under hi-m-inp ' + rd.cls + '" type="number" min="0" step="0.001" data-key="' + key + '" data-step="' + i + '" data-field="' + rd.field + '" placeholder="' + rd.ph + '"' + val + '>' + bulb + '</div></td>';
      }).join('');
      return '<tr><th class="hi-m-row-h">' + rd.label + '</th>' + cells + '</tr>';
    }).join('');
    var actCells = steps.map(function (s, i) {
      return '<td><button type="button" class="hi-col-calc" data-key="' + key + '" data-step="' + i + '">自动计算</button></td>';
    }).join('');
    bodyHtml += '<tr class="hi-m-row-act"><th class="hi-m-row-h">操作</th>' + actCells + '</tr>';
    body.innerHTML = bodyHtml;
  }

  function applyVaultToMatrix(key) {
    Object.keys(LOCAL_VAULT).forEach(function (vk) {
      if (vk.indexOf(key + ':') !== 0) return;
      var step = vk.split(':')[1];
      var v = LOCAL_VAULT[vk];
      if (!v) return;
      ['output', 'energy', 'ef'].forEach(function (field) {
        var inp = document.querySelector('.hi-m-inp[data-key="' + key + '"][data-step="' + step + '"][data-field="' + field + '"]');
        if (inp && v[field] != null && v[field] !== 0) inp.value = v[field];
      });
    });
  }

  function switchIndustry(ind) {
    if (!INDUSTRY_META[ind]) ind = 'steel';
    var scoped = getCompanyIndustryKey();
    if (scoped && ind !== scoped) ind = scoped;
    activeIndustry = ind;
    const meta = INDUSTRY_META[ind];
    ringMax = meta.ringMax;
    document.querySelectorAll('#hi-suite .hi-tab').forEach(function (b) {
      const on = (b.getAttribute('data-ind') || '') === ind;
      b.classList.toggle('on', on);
      b.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    mountFlow(meta.flow, meta.steps);
    mountMatrix(ind, meta);
    applyVaultToMatrix(ind);
    const titleEl = document.getElementById('hi-matrix-title');
    if (titleEl) titleEl.innerHTML = meta.title + ' <span id="hi-matrix-sub">' + meta.sub + '</span>';
    const indBench = document.getElementById('hi-bench-industry');
    const bestBench = document.getElementById('hi-bench-best');
    if (indBench) indBench.textContent = meta.bench.toFixed(meta.calcMode === 'rtk' ? 6 : 3);
    if (bestBench) bestBench.textContent = meta.best.toFixed(meta.calcMode === 'rtk' ? 6 : 3);
    var unitEl = document.getElementById('hi-ring-product');
    var ringUnit = document.getElementById('hi-ring-unit-disp');
    if (unitEl) unitEl.textContent = meta.unitLabel || '单位产品碳强度';
    if (ringUnit) ringUnit.textContent = meta.unitRing || 'tCO₂e/t';
    var pueEl = document.getElementById('hi-pue-readout');
    if (pueEl) pueEl.hidden = meta.calcMode !== 'idc';
    refreshRegionalPolicy();
    refreshCbamExpandWarning();
    refreshIndustryKpiStrip(meta);
    renderInfluenceRank(ind, true);
    localCalc();
  }

  function fmtEur(n) {
    if (n == null || isNaN(n)) return '€ 0';
    if (n >= 1000000) return '€ ' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '€ ' + Math.round(n / 1000) + 'K';
    return '€ ' + Math.round(n);
  }

  function meAlias() {
    var co = window.AppState && window.AppState.company;
    var cert = (co && co.verifiedFactorCertId) || '';
    if (cert && cert.length >= 4) return '本企业 · ' + cert.slice(-5).toUpperCase();
    return '本企业 · 待确权';
  }

  function meEmpowerCount(ind) {
    var m = window.AppState && window.AppState.metrics;
    if (!m) return 0;
    var base = Number(m.crusadeCount) || 0;
    return Math.max(0, Math.round(base * industryMetricShare(ind, 'crusade')));
  }

  function meTaxSaved(ind) {
    var m = window.AppState && window.AppState.metrics;
    var total = m && (Number(m.totalTaxPenalty) || Number(m.total_tax_penalty) || 0);
    if (!total) {
      var mockShare = { steel: 420000, cement: 210000, petro: 380000, paper: 180000, aviation: 520000, ceramic: 240000, port: 160000, idc: 290000 };
      return mockShare[ind] || 0;
    }
    return Math.round(total * industryMetricShare(ind, 'tax'));
  }

  function meConfidence() {
    var ia = window.AppState && window.AppState.industryAudit;
    if (ia && ia.localCarbonIntensity > 0) return 88;
    var co = window.AppState && window.AppState.company;
    if (co && co.verifiedFactor != null) return 82;
    return 68;
  }

  function countFilledSteps(ind) {
    var n = 0;
    var prefix = ind + ':';
    Object.keys(LOCAL_VAULT).forEach(function (k) {
      if (k.indexOf(prefix) !== 0) return;
      var v = LOCAL_VAULT[k];
      if (v && v.output > 0) n += 1;
    });
    return n;
  }

  function podiumMedal(rank) {
    if (rank === 1) return { cls: 'hi-pod-gold', stamp: 'I', label: '冠军' };
    if (rank === 2) return { cls: 'hi-pod-silver', stamp: 'II', label: '亚军' };
    return { cls: 'hi-pod-bronze', stamp: 'III', label: '季军' };
  }

  function renderPodiumCard(entry, rank) {
    var med = podiumMedal(rank);
    return '<article class="hi-pod-card ' + med.cls + '">' +
      '<div class="hi-pod-stamp" aria-hidden="true"><span class="hi-pod-stamp-num">' + med.stamp + '</span></div>' +
      '<div class="hi-pod-rank">#' + rank + '</div>' +
      '<div class="hi-pod-alias">' + entry.alias + ' <span class="hi-pod-tag">' + entry.tag + '</span></div>' +
      '<div class="hi-pod-eis"><span class="hi-pod-eis-val">' + entry.eis.toFixed(1) + '</span><span class="hi-pod-eis-lbl">EIS</span></div>' +
      '<div class="hi-pod-metrics">' +
        '<span>已赋能 <strong>' + entry.empower + '</strong> 家</span>' +
        '<span>挽回 <strong>' + fmtEur(entry.taxSaved) + '</strong></span>' +
      '</div>' +
      '</article>';
  }

  function renderListRow(entry, rank) {
    return '<li class="hi-inf-row">' +
      '<span class="hi-inf-rank-num">#' + rank + '</span>' +
      '<span class="hi-inf-alias">' + entry.alias + ' <em>' + entry.tag + '</em></span>' +
      '<span class="hi-inf-metric"><span class="hi-inf-m-lbl">赋能</span><strong>' + entry.empower + '</strong></span>' +
      '<span class="hi-inf-metric"><span class="hi-inf-m-lbl">节税</span><strong>' + fmtEur(entry.taxSaved) + '</strong></span>' +
      '<span class="hi-inf-eis">' + entry.eis.toFixed(1) + '</span>' +
      '</li>';
  }

  function renderInfluenceRank(ind, animate) {
    ind = ind || activeIndustry;
    var data = buildInfluenceEntries(ind);
    var labelEl = document.getElementById('hi-inf-ind-label');
    var podiumEl = document.getElementById('hi-inf-podium');
    var listEl = document.getElementById('hi-inf-list');
    var meEl = document.getElementById('hi-inf-me');
    var bodyEl = document.getElementById('hi-inf-body');
    var signalEl = document.getElementById('hi-inf-signal-chip');
    if (!podiumEl || !listEl || !meEl) return;

    if (labelEl) labelEl.textContent = INFLUENCE_LABELS[ind] || '行业榜';

    if (animate && bodyEl) {
      bodyEl.classList.remove('hi-inf-flip');
      void bodyEl.offsetWidth;
      bodyEl.classList.add('hi-inf-flip');
      bodyEl.addEventListener('animationend', function onEnd() {
        bodyEl.classList.remove('hi-inf-flip');
        bodyEl.removeEventListener('animationend', onEnd);
      });
    }

    if (data.length === 0) {
      podiumEl.innerHTML = '<p class="hi-inf-empty">暂无链上排名 · 完成确权后将汇入行业核验池</p>';
      listEl.innerHTML = '';
      if (signalEl) {
        signalEl.textContent = '待激活';
        signalEl.className = 'hi-inf-signal';
      }
    } else {
      podiumEl.innerHTML = data.slice(0, 3).map(function (e, i) {
        return renderPodiumCard(e, i + 1);
      }).join('');
      listEl.innerHTML = data.slice(3, 7).map(function (e, i) {
        return renderListRow(e, i + 4);
      }).join('');
      if (signalEl) {
        if (isOfficialCertified()) {
          signalEl.textContent = '官方认证计分中';
          signalEl.className = 'hi-inf-signal cert';
        } else {
          signalEl.textContent = '草案计分中';
          signalEl.className = 'hi-inf-signal ready';
        }
      }
    }

    var totalSteps = (INDUSTRY_META[ind] || INDUSTRY_META.steel).steps.length;
    var filled = countFilledSteps(ind);
    var st = window.AppState || {};
    var pending = Number(st.resonance && st.resonance.pendingRequestsForIndustry) ||
      Number(st.metrics && st.metrics.resonanceCount) || 0;
    var myRank = isOfficialCertified() ? Math.max(1, pending) : (pending > 0 ? pending + 1 : '—');
    var projected = filled >= totalSteps ? Math.max(1, Number(myRank) - 2) : '—';
    var empower = meEmpowerCount(ind);
    var tax = meTaxSaved(ind);
    var conf = meConfidence();
    var displayRank = myRank;
    var certifyMark = isOfficialCertified()
      ? '<span class="hi-inf-leader-badge">官方认证因子</span>'
      : '<span class="hi-inf-soft-badge">ℹ️ 本地草案</span>';
    var tip = '';
    var mainTip = (filled < totalSteps)
      ? '<p class="hi-inf-tip">💡 完成 1-' + totalSteps + ' 号工序精算，排名预计可升至第 <strong>' + projected + '</strong> 名</p>'
      : '<p class="hi-inf-tip hi-inf-tip-ready">✓ 工序精算已完成，建议生成投资评价报告呈送财务审批</p>';
    var policyTip = (!isOfficialCertified())
      ? '<p class="hi-inf-tip hi-inf-tip-audit">💡 完成官方确权后，EIS 将按完整权重计入行业影响力榜</p>'
      : '';
    tip = mainTip + policyTip;

    meEl.innerHTML =
      '<div class="hi-inf-me-main">' +
        '<span class="hi-inf-me-badge">当前企业</span>' +
        certifyMark +
        '<span class="hi-inf-me-rank">您当前排名：<strong>第 ' + displayRank + ' 名</strong></span>' +
        '<span class="hi-inf-me-alias">' + meAlias() + '</span>' +
        '<span class="hi-inf-me-metric">已赋能下游 <strong>' + empower + '</strong> 家</span>' +
        '<span class="hi-inf-me-metric">已挽回碳税 <strong>' + fmtEur(tax) + '</strong></span>' +
        '<span class="hi-inf-me-metric">数据置信度 <strong>' + conf + '%</strong></span>' +
      '</div>' + tip;

  }

  function readMatrix(key, steps) {
    const meta = INDUSTRY_META[key] || {};
    const rows = {};
    let totalOut = 0;
    let totalEmit = 0;
    document.querySelectorAll('.hi-m-inp[data-key="' + key + '"]').forEach(function (inp) {
      const step = inp.getAttribute('data-step');
      const field = inp.getAttribute('data-field');
      if (!rows[step]) {
        rows[step] = { name: steps[Number(step)][0], output: 0, energy: steps[Number(step)][2], ef: steps[Number(step)][1] };
      }
      rows[step][field] = parseFloat(inp.value) || 0;
    });

    var itMwh = (rows['0'] && rows['0'].output) || 0;
    var facilityMwh = 0;
    var pue = 0;

    Object.keys(rows).forEach(function (k) {
      const r = rows[k];
      const idx = Number(k);
      var emit = 0;
      var stepOut = r.output;

      if (meta.calcMode === 'idc') {
        var stepMwh = idx === 0 ? r.output : (itMwh > 0 ? itMwh * r.energy : r.output);
        if (idx > 0 && r.output > 0) stepMwh = r.output;
        emit = stepMwh * r.ef;
        facilityMwh += stepMwh;
        if (idx === 0) totalOut = r.output;
      } else {
        emit = r.output > 0 ? r.output * r.energy * r.ef : 0;
        if (r.output > 0) {
          totalOut += r.output;
        }
      }

      LOCAL_VAULT[key + ':' + k] = { output: r.output, energy: r.energy, ef: r.ef, emit: emit };
      const emitEl = document.querySelector('.hi-m-emit-val[data-key="' + key + '"][data-step="' + k + '"]');
      if (emitEl) emitEl.textContent = emit > 0 ? emit.toFixed(meta.calcMode === 'rtk' ? 4 : 2) : '—';
      totalEmit += emit;
    });

    if (meta.calcMode === 'idc' && itMwh > 0) {
      pue = facilityMwh / itMwh;
    }

    var ci = 0;
    if (meta.calcMode === 'idc') {
      ci = pue > 0 ? pue : 0;
    } else {
      ci = totalOut > 0 ? totalEmit / totalOut : 0;
    }

    updateStructureBar(key, steps);
    saveLocalVault();

    var pueEl = document.getElementById('hi-pue-readout');
    if (pueEl && meta.calcMode === 'idc') {
      pueEl.hidden = false;
      pueEl.textContent = 'PUE 实时核算：' + (pue > 0 ? pue.toFixed(3) : '—') +
        (totalEmit > 0 && itMwh > 0 ? ' · 算力碳强度 ' + (totalEmit / itMwh).toFixed(4) + ' tCO₂e/MWh' : '');
    }

    return { ci: ci, totalOut: totalOut, totalEmit: totalEmit, rows: rows, pue: pue };
  }

  function updateStructureBar(key, steps) {
    var d = 0, ind = 0, proc = 0;
    var n = steps.length;
    Object.keys(LOCAL_VAULT).forEach(function (vk) {
      if (vk.indexOf(key + ':') !== 0) return;
      var idx = Number(vk.split(':')[1]);
      var emit = (LOCAL_VAULT[vk] && LOCAL_VAULT[vk].emit) || 0;
      if (!emit) return;
      if (idx < Math.ceil(n / 3)) d += emit;
      else if (idx < Math.ceil(2 * n / 3)) ind += emit;
      else proc += emit;
    });
    var total = d + ind + proc;
    var pct = function (v) { return total > 0 ? Math.round((v / total) * 100) : 0; };
    var pd = pct(d), pi = pct(ind), pp = pct(proc);
    var elD = document.getElementById('hi-struct-direct');
    var elI = document.getElementById('hi-struct-indirect');
    var elP = document.getElementById('hi-struct-process');
    if (elD) elD.style.width = pd + '%';
    if (elI) elI.style.width = pi + '%';
    if (elP) elP.style.width = pp + '%';
    document.getElementById('hi-struct-pct-d').textContent = total ? pd + '%' : '—';
    document.getElementById('hi-struct-pct-i').textContent = total ? pi + '%' : '—';
    document.getElementById('hi-struct-pct-p').textContent = total ? pp + '%' : '—';
  }

  function updateDonut() {
    var counts = {};
    Object.keys(INDUSTRY_META).forEach(function (k) { counts[k] = 0; });
    Object.keys(LOCAL_VAULT).forEach(function (k) {
      const ind = k.split(':')[0];
      const v = LOCAL_VAULT[k];
      if (v && v.output > 0 && counts[ind] != null) counts[ind] += 1;
    });
    var total = Object.keys(counts).reduce(function (s, k) { return s + counts[k]; }, 0);
    if (!total && window.AppState && window.AppState.metrics) {
      const cc = Number(window.AppState.metrics.crusadeCount) || 0;
      if (cc > 0) {
        Object.keys(INDUSTRY_CRUSADE_SHARE).forEach(function (k) {
          counts[k] = Math.round(cc * (INDUSTRY_CRUSADE_SHARE[k] || 0));
        });
        total = cc;
      }
    }
    var sorted = Object.keys(counts).sort(function (a, b) { return counts[b] - counts[a]; });
    var top3 = sorted.filter(function (k) { return counts[k] > 0; }).slice(0, 3);
    if (top3.length < 3) {
      var fill = (window.HI_INDUSTRY_ORDER || Object.keys(INDUSTRY_META)).slice();
      fill.forEach(function (k) {
        if (top3.length >= 3) return;
        if (top3.indexOf(k) < 0) top3.push(k);
      });
      top3 = top3.slice(0, 3);
    }
    const pct = function (n) { return total ? Math.round((n / total) * 100) : 0; };
    var segPcts = top3.map(function (k) { return pct(counts[k] || 0); });
    var legend = document.querySelector('.hi-donut-legend');
    var dotCls = ['steel', 'al', 'cement'];
    if (legend) {
      legend.innerHTML = top3.map(function (k, i) {
        return '<li data-ind="' + k + '"><span class="hi-leg-dot ' + dotCls[i] + '"></span>' +
          (INDUSTRY_DISPLAY[k] || k) + ' <strong>' + segPcts[i] + '%</strong></li>';
      }).join('');
    }
    const cols = ['hi-donut-steel', 'hi-donut-al', 'hi-donut-cement'];
    let angle = -90;
    segPcts.forEach(function (p, i) {
      const el = document.getElementById(cols[i]);
      if (!el) return;
      const len = (p / 100) * CIRC;
      el.setAttribute('stroke-dasharray', len + ' ' + (CIRC - len));
      el.setAttribute('transform', 'rotate(' + angle + ' 60 60)');
      angle += (p / 100) * 360;
    });
  }

  function paintGaugeFrame(ci, meta, decimals) {
    const ringVal = document.getElementById('hi-ring-val');
    const arc = document.getElementById('hi-ring-arc');
    if (ringVal) ringVal.textContent = ci > 0 ? ci.toFixed(decimals) : '—';
    if (arc) {
      const frac = Math.min(ci / ringMax, 1);
      const len = frac * RING_CIRC;
      arc.setAttribute('stroke-dasharray', len + ' ' + (RING_CIRC - len));
    }
    const indEl = document.getElementById('hi-bench-industry');
    const bestEl = document.getElementById('hi-bench-best');
    if (indEl) indEl.textContent = meta.bench.toFixed(3);
    if (bestEl) bestEl.textContent = meta.best.toFixed(3);
    if (activeIndustry === 'steel' && window.AppState && window.AppState.metrics &&
        window.AppState.metrics.benchmarkCarbonIntensity != null) {
      if (indEl) indEl.textContent = Number(window.AppState.metrics.benchmarkCarbonIntensity).toFixed(3);
    }
  }

  function updateGauge(ci) {
    const meta = INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel;
    var decimals = meta.calcMode === 'rtk' ? 6 : (meta.calcMode === 'idc' ? 3 : 3);
    var target = Number(ci) > 0 ? Number(ci) : 0;
    if (prefersReducedMotion()) {
      gaugeDisplayCi = target;
      paintGaugeFrame(target, meta, decimals);
      updateDraftStatus(target);
      showPolicyCard(target);
      return;
    }
    if (gaugeAnimHandle) cancelAnimationFrame(gaugeAnimHandle);
    var from = Math.max(0, gaugeDisplayCi || 0);
    var delta = Math.abs(target - from);
    var duration = Math.min(900, Math.max(260, 260 + delta * 220));
    var start = performance.now();
    var tick = function (now) {
      var t = Math.min(1, (now - start) / duration);
      var e = 1 - Math.pow(1 - t, 3);
      var cur = from + (target - from) * e;
      gaugeDisplayCi = cur;
      paintGaugeFrame(cur, meta, decimals);
      if (t < 1) gaugeAnimHandle = requestAnimationFrame(tick);
      else {
        gaugeDisplayCi = target;
        paintGaugeFrame(target, meta, decimals);
      }
    };
    gaugeAnimHandle = requestAnimationFrame(tick);
    updateDraftStatus(target);
    showPolicyCard(target);
  }

  function updateSpark(pct) {
    const el = document.getElementById('hi-yoy-spark');
    const path = document.getElementById('hi-spark-path');
    const fill = document.getElementById('hi-spark-fill');
    if (!el) return;
    if (pct == null || !Number.isFinite(pct)) {
      el.textContent = '同比增减率 —';
      el.className = 'hi-spark-pct';
      return;
    }
    const txt = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%';
    el.textContent = '同比增减率 ' + txt;
    el.className = 'hi-spark-pct ' + (pct < 0 ? 'green' : 'warn');
    const base = 28;
    const amp = Math.min(Math.abs(pct) * 0.8, 14);
    const pts = [];
    for (let i = 0; i <= 8; i++) {
      const x = i * 25;
      const y = base + Math.sin(i * 0.9 + pct * 0.05) * amp * (pct < 0 ? -1 : 1);
      pts.push((i ? 'L' : 'M') + x + ',' + y.toFixed(1));
    }
    const d = pts.join(' ');
    if (path) path.setAttribute('d', d);
    if (fill) fill.setAttribute('d', d + ' L200,48 L0,48 Z');
  }

  function updateYoy(ci) {
    const prev = parseFloat(document.getElementById('hi-prev-ci').value);
    const yoyEl = document.getElementById('hi-yoy');
    if (!Number.isFinite(prev) || prev <= 0 || !ci) {
      yoyEl.textContent = '—';
      updateSpark(null);
      return null;
    }
    const pct = ((ci - prev) / prev) * 100;
    yoyEl.textContent = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%';
    yoyEl.className = 'hi-yoy-val ' + (pct < 0 ? 'green' : 'warn');
    updateSpark(pct);
    return pct;
  }

  function localCalc() {
    const meta = INDUSTRY_META[activeIndustry];
    const res = readMatrix(activeIndustry, meta.steps);
    document.getElementById('hi-curr-ci').value = res.ci > 0 ? res.ci.toFixed(4) : '';
    const yoyPct = updateYoy(res.ci);
    updateGauge(res.ci);
    updateDonut();
    if (window.AppState && typeof window.AppState.patchState === 'function') {
      window.AppState.patchState({
        industryAudit: Object.assign({}, window.AppState.industryAudit || {}, {
          localCarbonIntensity: res.ci,
          lastIndustry: activeIndustry,
          verifiedFactorYoyPct: yoyPct != null ? yoyPct : (window.AppState.industryAudit && window.AppState.industryAudit.verifiedFactorYoyPct),
        }),
      }, { emitStateSynced: false });
    }
    updateResonanceDashboard(res.ci, res.totalOut);
    renderInfluenceRank(activeIndustry, false);
    renderExecutionBrief(res.ci);
    return res.ci;
  }

  function queueRecalc() {
    if (recalcQueued) return;
    recalcQueued = true;
    requestAnimationFrame(function () {
      recalcQueued = false;
      localCalc();
    });
  }

  document.getElementById('hi-suite').addEventListener('input', function (e) {
    if (e.target && e.target.classList && e.target.classList.contains('hi-m-inp')) queueRecalc();
  });
  document.getElementById('hi-suite').addEventListener('click', function (e) {
    var b = e.target && e.target.closest ? e.target.closest('.hi-m-bulb') : null;
    if (!b) return;
    var v = b.getAttribute('data-bench');
    var lbl = b.getAttribute('data-lbl') || '该项';
    var txt = '💡 ' + lbl + ' 行业参考值：' + (v == null ? '—' : v);
    if (typeof showToast === 'function') showToast(txt);
  });
  document.getElementById('hi-prev-ci').addEventListener('input', function () {
    updateYoy(parseFloat(document.getElementById('hi-curr-ci').value) || 0);
  });

  function requirePledge() {
    return new Promise(function (resolve) {
      pledgeResolver = resolve;
      document.getElementById('hi-pledge').classList.add('show');
    });
  }

  document.getElementById('hi-pledge-cancel').addEventListener('click', function () {
    document.getElementById('hi-pledge').classList.remove('show');
    if (pledgeResolver) pledgeResolver(false);
    pledgeResolver = null;
  });
  document.getElementById('hi-pledge-ok').addEventListener('click', function () {
    document.getElementById('hi-pledge').classList.remove('show');
    if (pledgeResolver) pledgeResolver(true);
    pledgeResolver = null;
    if (pendingAction) {
      const fn = pendingAction;
      pendingAction = null;
      fn();
    }
  });

  function triggerGoldenBadge() {
    const flash = document.createElement('div');
    flash.className = 'hi-golden-flash';
    document.body.appendChild(flash);
    flash.addEventListener('animationend', function () { flash.remove(); });
    const toast = document.createElement('div');
    toast.className = 'hi-badge-toast show';
    toast.textContent = '🏅 CL-Origin 绿色出海先行者 · 已写入荣誉体系';
    document.body.appendChild(toast);
    toast.addEventListener('animationend', function () { toast.remove(); });
    if (window.AppState && typeof window.AppState.patchState === 'function') {
      var badges = (window.AppState.badges || []).slice();
      var code = 'CL-ORIGIN-PIONEER';
      if (!badges.some(function (b) { return (b.badgeCode || b.badge_code) === code; })) {
        badges.push({ badgeCode: code, badgeName: 'CL-Origin 绿色出海先行者' });
        window.AppState.patchState({ badges: badges });
      }
    }
    if (window.EventBus && typeof window.EventBus.emit === 'function') {
      window.EventBus.emit('BADGE_AWARDED', { code: 'CL-ORIGIN-PIONEER', name: 'CL-Origin 绿色出海先行者' });
    }
  }

  async function attestToPool() {
    const ci = localCalc();
    if (!ci || ci <= 0) {
      if (typeof showToast === 'function') showToast('请先完成工序矩阵录入');
      else alert('请先完成工序矩阵录入');
      return;
    }
    const yoy = updateYoy(ci);
    const metaAtt = INDUSTRY_META[activeIndustry] || INDUSTRY_META.steel;
    const body = {
      carbonIntensity: ci,
      yoyChangePct: yoy != null ? yoy : undefined,
      industryCode: activeIndustry,
      productLabel: metaAtt.productLabel,
      productionLine: getProductionLine(),
      intensityUnit: metaAtt.intensityUnit || 'tCO2e/t',
    };
    /* 物理隔离：仅脱敏系数落库，禁止携带 LOCAL_VAULT 工序绝对值 */
    persistProductionLine();
    try {
      let data;
      if (window.AppState && typeof window.AppState.commit === 'function') {
        data = await window.AppState.commit('industryAudit', body);
      } else {
        const res = await fetch(apiBase() + '/api/v1/hub/industry-factor-attest', {
          method: 'POST',
          credentials: 'include',
          headers: authHeaders(),
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error((await res.json().catch(function () { return {}; })).detail || res.statusText);
        data = await res.json();
        if (data.appState && typeof syncAppState === 'function') syncAppState(data.appState);
      }
      const cert = data.certId || data.cert_id || (data.appState && data.appState.company && data.appState.company.verifiedFactorCertId);
      const vcode = data.verificationCode || data.verification_code ||
        (data.appState && data.appState.company && (data.appState.company.verificationCode || data.appState.company.verification_code));
      if (cert) document.getElementById('hi-cert-display').textContent = cert;
      if (vcode) {
        var vcEl = document.getElementById('hi-verification-code');
        if (vcEl) vcEl.textContent = vcode;
      }
      if (data.badgeAwarded || data.badge_awarded) {
        triggerGoldenBadge();
        bindHonorBadge();
      }
      patchIndustryCommerce({ hasVerifiedFactor: true });
      applyEmpowermentUI();
      refreshResonanceHeader();
      if (cert) showGoldenSealCeremony(cert, vcode);
      if (typeof showToast === 'function') showToast((data.message || '因子已确权') + (vcode ? ' · 核验码 ' + vcode : ''));
      else if (typeof pulseHubAfterDataSync === 'function') pulseHubAfterDataSync(window.AppState);
    } catch (e) {
      const msg = (e && e.message) || '确权失败';
      if (typeof showToast === 'function') showToast(msg);
      else alert(msg);
    }
  }

  function buildClIvcSealSvg(size, line1, line2, line3, gold) {
    var s = size || 120;
    var stroke = gold ? '#c9a84c' : '#9ca3af';
    var fill = gold ? '#8b6914' : '#4b5563';
    var r = s / 2 - 4;
    var cx = s / 2;
    var fs1 = Math.round(s * 0.11);
    var fs2 = Math.round(s * 0.09);
    var fs3 = Math.round(s * 0.065);
    return '<svg xmlns="http://www.w3.org/2000/svg" width="' + s + '" height="' + s + '" viewBox="0 0 ' + s + ' ' + s + '">' +
      '<circle cx="' + cx + '" cy="' + cx + '" r="' + r + '" fill="none" stroke="' + stroke + '" stroke-width="3"/>' +
      '<circle cx="' + cx + '" cy="' + cx + '" r="' + (r - 8) + '" fill="none" stroke="' + stroke + '" stroke-width="1.5"/>' +
      '<text x="' + cx + '" y="' + (cx - fs1 * 0.3) + '" text-anchor="middle" font-family="SimSun,serif" font-size="' + fs1 + '" font-weight="bold" fill="' + fill + '">CL-IVC</text>' +
      '<text x="' + cx + '" y="' + (cx + fs2 * 0.9) + '" text-anchor="middle" font-family="SimSun,serif" font-size="' + fs2 + '" font-weight="bold" fill="' + fill + '">' + line1 + '</text>' +
      (line2 ? '<text x="' + cx + '" y="' + (cx + fs2 * 2.1) + '" text-anchor="middle" font-family="SimSun,serif" font-size="' + fs3 + '" fill="#666">' + line2 + '</text>' : '') +
      (line3 ? '<text x="' + cx + '" y="' + (cx + fs2 * 3.0) + '" text-anchor="middle" font-family="SimSun,serif" font-size="' + fs3 + '" fill="#888">' + line3 + '</text>' : '') +
      '</svg>';
  }

  function pdfShell(inner, minHeight) {
    return '<div style="position:relative;width:714px;min-height:' + (minHeight || 980) + 'px;padding:40px 44px;background:#ffffff;color:#111111;font-family:SimSun,serif;box-sizing:border-box;overflow:visible">' +
      inner + '</div>';
  }

  function buildCisaPdfHtml() {
    const co = (window.AppState && window.AppState.company) || {};
    const ia = (window.AppState && window.AppState.industryAudit) || {};
    const name = co.name || '企业';
    const cert = co.verifiedFactorCertId || document.getElementById('hi-cert-display').textContent || '—';
    const vcode = co.verificationCode || co.verification_code ||
      (document.getElementById('hi-verification-code') && document.getElementById('hi-verification-code').textContent) || '—';
    const ci = document.getElementById('hi-curr-ci').value || (ia.verifiedFactor != null ? ia.verifiedFactor : '—');
    const certified = isOfficialCertified();
    const period = new Date().toISOString().slice(0, 7);
    const sealSub = certified ? '已确权' : '官方钢印版';
    const sealNote = certified ? '' : '<p style="margin:8px 0 0;font-size:10px;color:#8b6914">ℹ️ 正式启动 CL-IVC 认证通道后，钢印编号将与核验池同步</p>';
    const cornerSeal = buildClIvcSealSvg(128, '官方钢印', sealSub, period, true);
    const wmSeal = buildClIvcSealSvg(220, 'CL-IVC', '合规月报', period, true);
    const body =
      '<div style="position:absolute;left:0;right:0;top:300px;text-align:center;opacity:0.13;z-index:0;pointer-events:none">' + wmSeal + '</div>' +
      '<div style="position:absolute;top:28px;right:28px;z-index:2;text-align:center">' + cornerSeal + sealNote + '</div>' +
      '<div style="position:relative;z-index:1">' +
      '<h1 style="text-align:center;font-size:20px;margin:0 0 6px">中国钢铁工业协会（CISA）风格 · 碳排放统计月报</h1>' +
      '<p style="text-align:center;font-size:11px;color:#666;margin:0 0 28px">带 CL-IVC 官方钢印 · ' + period + '</p>' +
      '<p style="margin-top:24px">企业名称：' + name + '</p>' +
      '<p>确权编号：' + cert + '</p>' +
      '<p>批次核验码：' + vcode + '</p>' +
      '<p>单位产品碳强度：' + ci + ' tCO₂e/t</p>' +
      '<p>报告期：' + period + '</p>' +
      '<div style="margin-top:48px;padding:14px 16px;border:2px double #c9a84c;border-radius:8px;text-align:center;background:rgba(201,168,76,0.06)">' +
      '<div style="display:inline-block">' + buildClIvcSealSvg(96, '钢印核验', certified ? '有效' : '待通道激活', '', true) + '</div>' +
      '<p style="margin:10px 0 0;font-size:11px;color:#8b6914;font-weight:bold">CL-IVC · 产业链合规赋能专项 · 官方钢印</p>' +
      '</div>' +
      '<p style="margin-top:40px;font-size:11px;color:#666">本报告仅含脱敏强度指标；工序绝对能耗未离机存储。HengAI · Co2Lion CL-IVC</p></div>';
    return pdfShell(body, 980);
  }

  function buildBudgetReportHtml() {
    var co = (window.AppState && window.AppState.company) || {};
