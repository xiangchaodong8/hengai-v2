# ── Secrets / env ──
.env
.env.*
!.env.example
backend/.env
**/*.pem
**/*.key
**/credentials.json
**/secrets.json

# ── Dependencies / build ──
node_modules/
frontend/node_modules/
**/__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
.cache/
*.log
npm-debug.log*

# ── OS / IDE ──
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo

# ── Docker / local DB dumps ──
*.sql.gz
*.dump

# ── Playwright / test artifacts ──
frontend/test-results/
frontend/playwright-report/
frontend/.auth/
**/blob-report/

# ── Recovery snapshots（本地回滚包，勿入库）──
_recovery/

# ── Optional local-only ──
*.local.html
.cursor/
!.cursorrules

# ── Large / generated duplicates（发版前用 npm run sync:dist，勿手改）──
# 保留 static_dist 入库策略：默认跟踪；若体积过大可改为只跟踪清单文件
# backend/static_dist 与根 static_dist 由 sync 生成，可二选一忽略其一：
backend/static_dist/

# ── BP / Word 临时提取 ──
docs/BP/_*.txt
docs/BP/~$*
~$*.docx
*.tmp
