        buildClIvcSealSvg(200, '投资评价', '预算申请', '', false) + '</div>' +
      '<div style="position:relative;z-index:1;line-height:1.65;color:#222">' +
      '<h1 style="text-align:center;font-size:18px;margin:0 0 8px">合规资产确权与投资评价报告</h1>' +
      '<p style="text-align:center;font-size:11px;color:#666;margin:0 0 28px">CL-IVC · 产业链合规赋能专项 · ' + today + '</p>' +
      '<h2 style="font-size:14px;border-left:4px solid #10b981;padding-left:8px">一、现状：下游合规压力</h2>' +
      '<p>经平台行为画像与产业链穿透测算，<strong>' + name + '</strong> 当前关联下游供应商约 <strong>' +
      downstream.toLocaleString('zh-CN') + '</strong> 家，正面临 CBAM / 国内绿证与出口合规双重压力。本次精算覆盖其中约 <strong>' +
      cov + '</strong> 家核心链路企业，亟需原厂级因子确权以降低传导风险。</p>' +
      '<h2 style="font-size:14px;border-left:4px solid #10b981;padding-left:8px;margin-top:22px">二、成果：本地精算碳强度优势</h2>' +
      '<p>基于 1-' + meta.steps.length + ' 号工序本地精算（数据仅存 LOCAL_VAULT），当前单位产品碳强度为 <strong>' +
      (ci > 0 ? ci.toFixed(3) : '—') + ' tCO₂e/t</strong>。相较行业对标基准，测算优势约 <strong>' + advTxt + '</strong>。</p>' +
      '<p style="font-size:11px;color:#666">ℹ️ 上述为内部参考草案，正式出口确权须完成 CL-IVC 官方算法校准。</p>' +
      '<h2 style="font-size:14px;border-left:4px solid #c9a84c;padding-left:8px;margin-top:22px">三、投资：官方确权技术服务费</h2>' +
      '<p>启动产业链合规赋能专项服务（含 CL-IVC 官方认证通道、核验池写入与算力包 <strong>' + units +
      '</strong> 单元），预估技术服务费 <strong>' + fee + '</strong>。费用纳入年度技改与数字化专项预算科目。</p>' +
      '<h2 style="font-size:14px;border-left:4px solid #3b82f6;padding-left:8px;margin-top:22px">四、对冲：绿色制造政策补贴申报指引</h2>' +
      '<ul style="font-size:12px;padding-left:18px">' +
      '<li>『十五五绿色制造数字化转型』专项：技术服务费可计入技改投资，申请 <strong>30% 以上</strong>财政补贴（各地细则略有差异）。</li>' +
      '<li>工信部绿色工厂 / 绿色供应链评价：确权因子可作为碳管理体系建设佐证材料。</li>' +
      '<li>财务报销路径建议：「管理费用—技术服务费」或「在建工程—数字化改造」，附本报告及合同发票呈批。</li>' +
      '<li>💡 建议经办人先将本报告与工序精算摘要一并提交财务与技改委员会预审。</li>' +
      '</ul>' +
      '<div style="margin-top:28px;padding:12px;border:1px dashed #9ca3af;border-radius:8px;text-align:center">' +
        footerSeal +
        '<p style="margin:8px 0 0;font-size:10px;color:#4b5563">CL-IVC 预算申请专用章 · 供财务与技改委员会签批</p></div>' +
      '<p style="margin-top:16px;font-size:10px;color:#888;border-top:1px solid #ddd;padding-top:12px">本报告由 HengAI 因子精算战情室自动生成 · 工序绝对能耗未离机 · Co2Lion CL-IVC</p></div>',
      1100);
  }

  async function renderPdfToFile(html, filename) {
    if (typeof html2pdf === 'undefined') {
      if (typeof showToast === 'function') showToast('PDF 组件未加载');
      return false;
    }
    var prevScroll = window.scrollY || 0;
    window.scrollTo(0, 0);

    var host = document.createElement('div');
    host.className = 'hi-pdf-export-host';
    host.style.cssText = 'position:fixed;left:0;top:0;width:794px;max-width:794px;margin:0;padding:0;background:#fff;color:#111;z-index:2147483646;opacity:0.01;pointer-events:none;overflow:visible;box-sizing:border-box';
    host.innerHTML = html;
    document.body.appendChild(host);

    await new Promise(function (r) { requestAnimationFrame(function () { requestAnimationFrame(r); }); });
    await new Promise(function (r) { setTimeout(r, 200); });

    var contentH = Math.max(host.scrollHeight, host.offsetHeight, 1123);
    try {
      await html2pdf().set({
        margin: [12, 12, 14, 12],
        filename: filename,
        html2canvas: {
          scale: 2,
          backgroundColor: '#ffffff',
          logging: false,
          useCORS: true,
          scrollY: 0,
          scrollX: 0,
          windowWidth: 794,
          width: 794,
          height: contentH,
          y: 0,
        },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
        pagebreak: { mode: ['css', 'legacy'], avoid: ['tr', '.sign'] },
      }).from(host).save();
      return true;
    } catch (err) {
      console.error('PDF export failed', err);
      return false;
    } finally {
      if (host.parentNode) host.parentNode.removeChild(host);
      window.scrollTo(0, prevScroll);
    }
  }

  async function exportBudgetReportPdf() {
    var ci = parseFloat(document.getElementById('hi-curr-ci').value) || 0;
    if (!ci || ci <= 0) {
      if (typeof showToast === 'function') showToast('请先完成 1-9 号工序矩阵精算');
      return;
    }
    var ok = await renderPdfToFile(
      buildBudgetReportHtml(),
      'CL-IVC-Investment-Report-' + (new Date().toISOString().slice(0, 10)) + '.pdf'
    );
    if (!ok) return;
    patchIndustryCommerce({ budgetReportExportedAt: new Date().toISOString() });
    if (typeof showToast === 'function') showToast('投资评价报告已导出 · 含预算专用章 · 可呈送财务审批');
  }

  async function exportPdf() {
    var ok = await renderPdfToFile(
      buildCisaPdfHtml(),
      'CISA-Carbon-Monthly-Sealed-' + (new Date().toISOString().slice(0, 7)) + '.pdf'
    );
    if (ok && typeof showToast === 'function') showToast('带钢印合规月报已导出 · 请查看 PDF 右上角与页内钢印区');
  }

  function showHistory() {
    const keys = Object.keys(LOCAL_VAULT);
    if (!keys.length) {
      if (typeof showToast === 'function') showToast('暂无本地工序快照，请先录入矩阵');
      return;
    }
    const lines = keys.slice(0, 12).map(function (k) {
      const v = LOCAL_VAULT[k];
      return k + ': ' + (v.output || 0) + 't · ' + (v.energy || 0) + ' GJ/t';
    });
    if (typeof showToast === 'function') showToast('LOCAL_VAULT · ' + lines.join(' | '));
    else alert(lines.join('\n'));
  }
  function jumpToExecutionBoard(pageId, fallbackUrl) {
    try {
      if (window.parent && window.parent !== window) {
        if (typeof window.parent.hengaiSwitchHubPage === 'function') {
          window.parent.hengaiSwitchHubPage(pageId);
          return true;
        }
        if (typeof window.parent.navTo === 'function') {
          var nav = window.parent.document && (window.parent.document.getElementById('nav-' + pageId) || window.parent.document.getElementById('n-' + pageId));
          window.parent.navTo(pageId, nav || null);
          return true;
        }
        window.parent.postMessage({ type: 'HENGAI_HUB_NAV', pageId: pageId }, '*');
        return true;
      }
    } catch (_) {}
    try {
      if (typeof window.hengaiSwitchHubPage === 'function') {
        window.hengaiSwitchHubPage(pageId);
        return true;
      }
    } catch (_) {}
    window.location.href = fallbackUrl;
    return true;
  }
  function routeAttestExecution(evt) {
    if (evt && evt.altKey) {
      requireOfficialChannel(function () {
        pendingAction = function () {
          triggerPressAnimation(function () { attestToPool(); });
        };
        requirePledge().then(function (ok) { if (!ok) pendingAction = null; });
      });
      return;
    }
    jumpToExecutionBoard('batch-verify', 'HengAI_核验.html');
    if (typeof showToast === 'function') showToast('已切换到核验中心：请在批次流中完成审批与签发');
  }
  function routeFactorExecution(evt) {
    if (evt && evt.altKey) {
      requireOfficialChannel(function () {
        pendingAction = exportPdf;
        requirePledge().then(function (ok) { if (!ok) pendingAction = null; });
      });
      return;
    }
    jumpToExecutionBoard('factor-auth', 'HengAI_工业原厂精算.html');
    if (typeof showToast === 'function') showToast('已切换到工业原厂因子精算：请在该页执行入池发布');
  }

  document.getElementById('hi-btn-budget-report').addEventListener('click', exportBudgetReportPdf);
  document.getElementById('hi-btn-attest').addEventListener('click', routeAttestExecution);
  document.getElementById('hi-btn-pdf').addEventListener('click', routeFactorExecution);
  var briefCalcBtn = document.getElementById('hi-btn-brief-calc');
  if (briefCalcBtn) briefCalcBtn.addEventListener('click', function () {
    jumpToExecutionBoard('factor-auth', 'HengAI_工业原厂精算.html');
  });
  var briefVerifyBtn = document.getElementById('hi-btn-brief-verify');
  if (briefVerifyBtn) briefVerifyBtn.addEventListener('click', function () {
    jumpToExecutionBoard('batch-verify', 'HengAI_核验.html');
  });
  var briefSupplyBtn = document.getElementById('hi-btn-brief-supply');
  if (briefSupplyBtn) briefSupplyBtn.addEventListener('click', function () {
    jumpToExecutionBoard('supply', 'HengAI_供应链协同.html');
  });
  document.getElementById('hi-modal-convert-cancel').addEventListener('click', function () {
    closeCommerceModal('hi-modal-convert');
    pendingConvertCallback = null;
  });
  document.getElementById('hi-modal-convert-budget').addEventListener('click', function () {
    closeCommerceModal('hi-modal-convert');
    pendingConvertCallback = null;
    exportBudgetReportPdf();
  });
  document.getElementById('hi-modal-convert-ok').addEventListener('click', function () {
